module aws.eks.podidentityassociation

import "@formae/formae.pkl"
import "../aws.pkl"

const type = "AWS::EKS::PodIdentityAssociation"

open class PodIdentityAssociationResolvable extends formae.Resolvable {
    hidden type = module.type


    hidden id: PodIdentityAssociationResolvable = (this) {
        property = "AssociationArn"
    }

    hidden arn: PodIdentityAssociationResolvable = (this) {
        property = "AssociationArn"
    }
    hidden associationArn: PodIdentityAssociationResolvable = (this) {
        property = "AssociationArn"
    }

    hidden associationId: PodIdentityAssociationResolvable = (this) {
        property = "AssociationId"
    }
}

@aws.ResourceHint {
    type = module.type
    identifier = "AssociationArn"
    parent = "AWS::EKS::Cluster"
    listParam = new formae.ListProperty { parentProperty = "Name" listParameter = "ClusterName" }
}
open class PodIdentityAssociation extends formae.Resource {

    hidden parent = this

    hidden res: PodIdentityAssociationResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }

    @aws.FieldHint{createOnly = true}
    clusterName: String|formae.Resolvable

    @aws.FieldHint{createOnly = true}
    namespace: String

    @aws.FieldHint
    roleArn: String|formae.Resolvable

    @aws.FieldHint{createOnly = true}
    serviceAccount: String

    @aws.FieldHint {
        updateMethod = "EntitySet"
        indexField = "Key"
    }
    tags: Listing<aws.Tag>?
}
