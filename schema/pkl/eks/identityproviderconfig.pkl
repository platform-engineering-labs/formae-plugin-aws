module aws.eks.identityproviderconfig

import "@formae/formae.pkl"
import "../aws.pkl"

const type = "AWS::EKS::IdentityProviderConfig"

@aws.SubResourceHint
open class RequiredClaim extends formae.SubResource {
    key: String
    value: String
}

@aws.SubResourceHint
open class OidcIdentityProviderConfig extends formae.SubResource {
    clientId: String
    groupsClaim: String?
    groupsPrefix: String?
    issuerUrl: String
    requiredClaims: Listing<RequiredClaim>?
    usernameClaim: String?
    usernamePrefix: String?
}

@aws.ResourceHint {
    type = module.type
    identifier = "IdentityProviderConfigArn"
    parent = "AWS::EKS::Cluster"
    listParam = new formae.ListProperty { parentProperty = "Name" listParameter = "ClusterName" }
}
open class IdentityProviderConfig extends formae.Resource {

    @aws.FieldHint{createOnly = true}
    clusterName: String|formae.Resolvable

    @aws.FieldHint{createOnly = true}
    identityProviderConfigName: String?

    @aws.FieldHint{createOnly = true}
    oidc: OidcIdentityProviderConfig?

    @aws.FieldHint {
        updateMethod = "EntitySet"
        indexField = "Key"
    }
    tags: Listing<aws.Tag>?

    @aws.FieldHint{createOnly = true}
    type: String
}
