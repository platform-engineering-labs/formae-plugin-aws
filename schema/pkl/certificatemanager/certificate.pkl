 *
 * Region pinning: CloudFront only accepts ACM certificates from us-east-1.
 * Operators consuming this resource for a CloudFront Distribution should
 * declare a separate formae.Target pinned to us-east-1 and place the
 * Certificate resource on that Target.
 *
 * DNS validation: validationRecords are exposed on CertificateResolvable
 * (populated by the custom Read provisioner at pkg/cfres/certificatemanager/
 * certificate.go, landing in Task 4). Consume via
 * cert.res.validationRecords.at(0).{name, recordType, value} for the
 * first cert SAN's CNAME challenge.
 */

module aws.certificatemanager.certificate

import "@formae/formae.pkl"
import "../aws.pkl"
import "../ses/ses.pkl" as ses

const type = "AWS::CertificateManager::Certificate"

typealias CertValidationMethodType = "EMAIL"|"DNS"

typealias CertKeyAlgorithmType =
    "RSA_2048"|"EC_prime256v1"|"EC_secp384r1"|"RSA_1024"|"RSA_4096"|"EC_secp521r1"

typealias CertTransparencyPreferenceType = "ENABLED"|"DISABLED"


@aws.SubResourceHint
open class DomainValidationOption extends formae.SubResource {
    domainName: String

    @aws.FieldHint{edgeKind = "runtimeDependency"}
    hostedZoneId: (String|formae.Resolvable)?

    validationDomain: String?
}


open class CertificateResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden arn: CertificateResolvable = (this) {
        property = "Id"
    }

    /// Populated by the custom Read provisioner — see
    /// pkg/cfres/certificatemanager/certificate.go (Task 4). Each entry
    /// exposes `name`, `recordType` (aliased because Resolvable reserves
    /// `type`), and `value`. Consume the first SAN's challenge as
    /// `cert.res.validationRecords.at(0).name` etc.
    hidden validationRecords: ses.DnsRecordListingResolvable = new ses.DnsRecordListingResolvable {
        label = this.label
        type = this.type
        stack = this.stack
        property = "ValidationRecords"
    }
}


@aws.ResourceHint {
    type = module.type
    identifier = "Id"
}
open class Certificate extends formae.Resource {

    @aws.FieldHint { createOnly = true }
    domainName: String

    @aws.FieldHint { createOnly = true }
    subjectAlternativeNames: Listing<String>?

    @aws.FieldHint { createOnly = true }
    domainValidationOptions: Listing<DomainValidationOption>?

    @aws.FieldHint { createOnly = true }
    certificateAuthorityArn: (String|formae.Resolvable)?

    certificateTransparencyLoggingPreference: CertTransparencyPreferenceType?

    @aws.FieldHint { createOnly = true }
    keyAlgorithm: CertKeyAlgorithmType?

    @aws.FieldHint { createOnly = true }
    validationMethod: CertValidationMethodType?

    certificateExport: String?

    @aws.FieldHint {
        outputTransformation = formae.transform.capitalizeMemberKeys
        updateMethod = "EntitySet"
        indexField = "Key"
    }
    tags: Listing<aws.Tag>?

    local parent = this

    hidden res: CertificateResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
