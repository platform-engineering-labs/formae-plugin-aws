module aws.ses.types

import "../aws.pkl"
import "@formae/formae.pkl"

// в”Ђв”Ђ DNS record value-object (provider-neutral) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

typealias DnsRecordType = "TXT"|"CNAME"|"MX"|"A"|"AAAA"

class DnsRecord {
    /// DNS record type.
    type: DnsRecordType
    /// FQDN, no trailing dot.
    name: String
    /// Multi-value record. Route53 native; Cloudflare splits one record per value.
    values: Listing<String>(this.length > 0)
    /// Recommended TTL in seconds.
    recommendedTtl: Int = 300
    /// MX/SRV priority. Route53 stuffs into the value string; Cloudflare uses a
    /// separate field. Always populated for "MX" records.
    priority: Int?
}

// в”Ђв”Ђ SES enum typealiases (SESv2 SCREAMING_SNAKE_CASE) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

typealias TlsPolicy = "REQUIRE"|"OPTIONAL"
typealias HttpsPolicy = "REQUIRE"|"REQUIRE_OPEN_ONLY"|"OPTIONAL"
typealias MatchingEventType = "SEND"|"REJECT"|"BOUNCE"|"COMPLAINT"|"DELIVERY"|"OPEN"|"CLICK"|"RENDERING_FAILURE"|"DELIVERY_DELAY"|"SUBSCRIPTION"
typealias BehaviorOnMxFailure = "USE_DEFAULT_VALUE"|"REJECT_MESSAGE"
typealias DkimSigningKeyLength = "RSA_1024_BIT"|"RSA_2048_BIT"
typealias SuppressedReason = "BOUNCE"|"COMPLAINT"
typealias DimensionValueSource = "MESSAGE_TAG"|"EMAIL_HEADER"|"LINK_TAG"
typealias VerificationStatus = "PENDING"|"SUCCESS"|"FAILED"|"TEMPORARY_FAILURE"|"NOT_STARTED"
typealias EngagementMetricsState = "ENABLED"|"DISABLED"
typealias OptimizedSharedDeliveryState = "ENABLED"|"DISABLED"

// в”Ђв”Ђ EmailIdentity attribute sub-classes в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

@aws.SubResourceHint
open class MailFromAttributes extends formae.SubResource {
    /// e.g. "mail.example.com"
    @aws.FieldHint { createOnly = true }
    mailFromDomain: String

    behaviorOnMxFailure: BehaviorOnMxFailure = "USE_DEFAULT_VALUE"
}

@aws.SubResourceHint
open class FeedbackAttributes extends formae.SubResource {
    emailForwardingEnabled: Boolean = true
}

@aws.SubResourceHint
open class DkimSigningAttributes extends formae.SubResource {
    /// Easy DKIM signing key length. AWS rotates the keys; you publish 3 CNAMEs once.
    nextSigningKeyLength: DkimSigningKeyLength = "RSA_2048_BIT"
}

// в”Ђв”Ђ ConfigurationSet sub-classes в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

@aws.SubResourceHint
open class DeliveryOptions extends formae.SubResource {
    tlsPolicy: TlsPolicy = "OPTIONAL"
    /// 5 min вЂ“ 14 hrs (300 .. 50400).
    maxDeliverySeconds: Int(isBetween(300, 50400))?
}

@aws.SubResourceHint
open class ReputationOptions extends formae.SubResource {
    reputationMetricsEnabled: Boolean = true
}

@aws.SubResourceHint
open class SendingOptions extends formae.SubResource {
    sendingEnabled: Boolean = true
}

@aws.SubResourceHint
open class SuppressionOptions extends formae.SubResource {
    suppressedReasons: Listing<SuppressedReason>?
}

@aws.SubResourceHint
open class TrackingOptions extends formae.SubResource {
    customRedirectDomain: String?
    httpsPolicy: HttpsPolicy = "REQUIRE"
}

@aws.SubResourceHint
open class VdmOptions extends formae.SubResource {
    dashboardOptions: DashboardOptions?
    guardianOptions: GuardianOptions?
}

@aws.SubResourceHint
open class DashboardOptions extends formae.SubResource {
    engagementMetrics: EngagementMetricsState = "ENABLED"
}

@aws.SubResourceHint
open class GuardianOptions extends formae.SubResource {
    optimizedSharedDelivery: OptimizedSharedDeliveryState = "ENABLED"
}

// в”Ђв”Ђ EventDestination sub-classes в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

@aws.SubResourceHint
open class SnsDestinationConfig extends formae.SubResource {
    /// SNS topic ARN. Resolves to AWS::SNS::Topic.
    @aws.FieldHint { outputField = "TopicARN" }
    topic: String|formae.Resolvable
}

@aws.SubResourceHint
open class KinesisFirehoseDestinationConfig extends formae.SubResource {
    /// Firehose delivery stream ARN.
    @aws.FieldHint { outputField = "DeliveryStreamARN" }
    deliveryStream: String|formae.Resolvable
    /// IAM role ARN that SES assumes to write to Firehose.
    @aws.FieldHint { outputField = "IAMRoleARN" }
    iamRole: String|formae.Resolvable
}

@aws.SubResourceHint
open class EventBridgeDestinationConfig extends formae.SubResource {
    /// EventBridge bus ARN.
    @aws.FieldHint { outputField = "EventBusArn" }
    eventBus: String|formae.Resolvable
}

@aws.SubResourceHint
open class CloudWatchDestinationConfig extends formae.SubResource {
    /// At least one dimension configuration is required.
    dimensionConfigurations: Listing<DimensionConfiguration>(this.length > 0)
}

/// Nested EventDestination config (the body of the CFN
/// `AWS::SES::ConfigurationSetEventDestination` resource's
/// `EventDestination` property).
@aws.SubResourceHint
open class EventDestinationDefinition extends formae.SubResource {
    /// Friendly destination name. Becomes part of the resource's
    /// `Id` (the CFN primary identifier).
    name: String?

    enabled: Boolean = true

    matchingEventTypes: Listing<MatchingEventType>(this.length > 0)

    snsDestination: SnsDestinationConfig?
    kinesisFirehoseDestination: KinesisFirehoseDestinationConfig?
    eventBridgeDestination: EventBridgeDestinationConfig?
    cloudWatchDestination: CloudWatchDestinationConfig?

    /// Eagerly enforced "exactly one destination" invariant. The field's value
    /// is derived from the four `*Destination` siblings; PKL's
    /// `Int(this == 1)` type constraint fires at instance construction, so a
    /// forma with zero or two-plus destinations fails at `pkl eval` rather
    /// than at apply time. `outputCondition = (_) -> false` keeps the field
    /// out of the JSON sent to CCAPI (CFN's schema doesn't have it).
    @aws.FieldHint { outputCondition = (_) -> false }
    fixed _destinationCount: Int(this == 1) =
        List(snsDestination, kinesisFirehoseDestination,
             eventBridgeDestination, cloudWatchDestination)
            .count((d) -> d != null)
}

@aws.SubResourceHint
open class DimensionConfiguration extends formae.SubResource {
    dimensionName: String
    dimensionValueSource: DimensionValueSource
    defaultDimensionValue: String
}

// в”Ђв”Ђ DnsRecord resolvable wrappers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
//
// EmailIdentity exposes `requiredDnsRecords` as a computed Listing<DnsRecord>
// in its resource state (populated by the custom Read provisioner). These
// resolvable wrappers let formae authors reference individual records by
// index вЂ” e.g. `id.res.requiredDnsRecords.at(0).name` resolves at apply
// time to the first DKIM CNAME's name.
//
// JSON keys come from the Go-side DnsRecord struct's JSON tags
// (see pkg/cfres/ses/emailidentity.go): PascalCase (Type/Name/Values/
// RecommendedTtl/Priority).

open class DnsRecordResolvable extends formae.MappingResolvable {
    local _self = this

    /// Renamed from `type` because Resolvable already declares a `type` slot.
    hidden recordType: formae.Resolvable = (_self.at("Type"))
    hidden name: formae.Resolvable = (_self.at("Name"))
    hidden values: formae.ListingResolvable = new formae.ListingResolvable {
        label = _self.label
        type = _self.type
        stack = _self.stack
        property = if (_self.property != null) _self.property + ".Values" else "Values"
        visibility = _self.visibility
    }
    hidden recommendedTtl: formae.Resolvable = (_self.at("RecommendedTtl"))
    hidden priority: formae.Resolvable = (_self.at("Priority"))
}

open class DnsRecordListingResolvable extends formae.ListingResolvable {
    local _self = this

    function at(index: Int): DnsRecordResolvable = new DnsRecordResolvable {
        label = _self.label
        type = _self.type
        stack = _self.stack
        property = if (_self.property != null)
            _self.property + "." + index.toString()
            else index.toString()
        visibility = _self.visibility
    }
}
