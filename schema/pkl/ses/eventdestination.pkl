module aws.ses.eventdestination

import "../aws.pkl"
import "@formae/formae.pkl"
import "ses.pkl" as ses

const type = "AWS::SES::EventDestination"

@aws.ResourceHint {
    type = module.type
    identifier = "EventDestinationName"
    parent = "AWS::SES::ConfigurationSet"
    listParam = new formae.ListProperty {
        parentProperty = "Name"
        listParameter = "ConfigurationSetName"
    }
    discoverable = true
}
open class EventDestination extends formae.Resource {

    @aws.FieldHint { createOnly = true }
    eventDestinationName: String

    /// Resolves to AWS::SES::ConfigurationSet (use myCs.res.name).
    @aws.FieldHint { createOnly = true }
    configurationSet: String|formae.Resolvable

    @aws.FieldHint
    enabled: Boolean = true

    @aws.FieldHint
    matchingEventTypes: Listing<ses.MatchingEventType>(this.length > 0)

    /// Discriminated-union shape: exactly one of the four `*Destination` fields
    /// must be set. v1 enforces this at apply time via CloudControl's
    /// ExactlyOneOf validation against the underlying CFN
    /// `AWS::SES::ConfigurationSetEventDestination` schema. A schema-flattener
    /// shift-left invariant was attempted but PKL evaluates `hidden`
    /// properties lazily, so it never fires; restoring shift-left enforcement
    /// is tracked as a follow-up (see ses-support design Section 7 risk #1).
    @aws.FieldHint
    snsDestination: ses.SnsDestinationConfig?

    @aws.FieldHint
    kinesisFirehoseDestination: ses.KinesisFirehoseDestinationConfig?

    @aws.FieldHint
    eventBridgeDestination: ses.EventBridgeDestinationConfig?

    @aws.FieldHint
    cloudWatchDestination: ses.CloudWatchDestinationConfig?
}
