amends "../eventdestination.pkl"

eventDestinationName = "bounce-route"
configurationSet = "hub-transactional"
matchingEventTypes = new { "BOUNCE"; "COMPLAINT" }
snsDestination = new { topic = "arn:aws:sns:us-east-1:123:Bounces" }
eventBridgeDestination = new { eventBus = "arn:aws:events:us-east-1:123:event-bus/default" }
