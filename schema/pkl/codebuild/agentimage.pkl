module aws.codebuild.agentimage

import "@formae/formae.pkl"
import "../aws.pkl"

const type = "AWS::CodeBuild::AgentImage"

/// Read-only outputs produced by the build, referenceable as resolvables via
/// `agentImage.res.*`. `imageRef` (repo@sha256:…) is the immutable, primary
/// consumption reference; `imageUri` (repo:tag) is a convenience mutable alias.
open class AgentImageResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden imageRef: AgentImageResolvable = (this) {
        property = "ImageRef"
    }

    hidden imageDigest: AgentImageResolvable = (this) {
        property = "ImageDigest"
    }

    hidden imageUri: AgentImageResolvable = (this) {
        property = "ImageUri"
    }

    hidden imageTag: AgentImageResolvable = (this) {
        property = "ImageTag"
    }
}

typealias PluginChannel = "stable"|"dev"

typealias ComputeType = "BUILD_GENERAL1_SMALL"|"BUILD_GENERAL1_MEDIUM"|"BUILD_GENERAL1_LARGE"

/// A plugin to install into the agent image. `version` is required so builds are
/// version-pinned; `channel` selects the hub distribution channel.
@aws.SubResourceHint
open class Plugin extends formae.SubResource {
    name: String(matches(Regex(#"^[a-z0-9]+(?:-[a-z0-9]+)*$"#)))
    version: String(matches(Regex(#"^[0-9]+\.[0-9]+\.[0-9]+(?:-[0-9A-Za-z.]+)?$"#)))
    channel: PluginChannel = "stable"
}

@aws.ResourceHint {
    type = module.type
    identifier = "ImageRef"
    discoverable = false
}
open class AgentImage extends formae.Resource {

    /// ECR repository URI to push to (registry/repo). Resolvable from an
    /// AWS::ECR::Repository's `repositoryUri`. Part of the resource identity.
    @aws.FieldHint { createOnly = true }
    ecrRepositoryUri: (String|formae.Resolvable)

    /// Human-facing tag for the pushed image. Part of the resource identity.
    @aws.FieldHint { createOnly = true }
    imageTag: String(matches(Regex(#"^[A-Za-z0-9_][A-Za-z0-9_.-]{0,127}$"#)))

    /// The FROM reference for the generated Dockerfile. SHOULD be digest-pinned
    /// for reproducibility; the returned digest is the source of truth regardless.
    @aws.FieldHint
    baseImage: String(matches(Regex(#"^[^\s]+$"#)))

    /// Extra or overridden plugins to install; order-insensitive, unique by name.
    @aws.FieldHint
    plugins: Listing<Plugin>?

    /// CodeBuild compute size for the build project. Defaults to SMALL.
    @aws.FieldHint
    computeType: ComputeType?

    /// Build timeout in minutes. Must be shorter than the engine's async poll
    /// deadline. Defaults to 30.
    @aws.FieldHint
    timeoutMinutes: (Int(this >= 5 && this <= 60))?

    /// BYO CodeBuild service role ARN. When supplied the plugin never creates,
    /// mutates, or deletes the role. Resolvable from an AWS::IAM::Role.
    @aws.FieldHint
    serviceRoleArn: (String|formae.Resolvable)?

    /// CodeBuild build-environment image (docker-in-docker capable). Defaults to a
    /// pinned aws/codebuild/standard image.
    @aws.FieldHint
    buildEnvironmentImage: String?

    // ── Computed outputs ────────────────────────────────────────

    /// Immutable digest reference `<repo>@sha256:…` — the primary output.
    @aws.FieldHint { hasProviderDefault = true }
    imageRef: String?

    /// The pushed manifest digest `sha256:…` alone.
    @aws.FieldHint { hasProviderDefault = true }
    imageDigest: String?

    /// Convenience mutable alias `<repo>:<tag>`.
    @aws.FieldHint { hasProviderDefault = true }
    imageUri: String?

    /// Hash over the build-affecting inputs; used to gate rebuilds.
    @aws.FieldHint { hasProviderDefault = true }
    buildConfigHash: String?

    local parent = this

    hidden res: AgentImageResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
