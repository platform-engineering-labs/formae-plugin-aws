module aws.ec2.ipamresourcediscovery

import "@formae/formae.pkl"
import "../aws.pkl"

const type = "AWS::EC2::IPAMResourceDiscovery"

open class IPAMResourceDiscoveryResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden ipamResourceDiscoveryId: IPAMResourceDiscoveryResolvable = (this) {
        property = "IpamResourceDiscoveryId"
    }
}

@aws.SubResourceHint
open class IPAMResourceDiscoveryIpamOperatingRegion extends formae.SubResource {
    regionName: aws.Region
}

@aws.ResourceHint {
    type = module.type
    identifier = "IpamResourceDiscoveryId"
}
open class IPAMResourceDiscovery extends formae.Resource {

    @aws.FieldHint
    description: String?

    @aws.FieldHint
    operatingRegions: Listing<IPAMResourceDiscoveryIpamOperatingRegion>?

    @aws.FieldHint {
        updateMethod = "EntitySet"
        indexField = "Key"
    }
    tags: Listing<aws.Tag>?

    local parent = this

    hidden res: IPAMResourceDiscoveryResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
