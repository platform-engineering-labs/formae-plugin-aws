module aws.ec2.dhcpoptions

import "@formae/formae.pkl"
import "../aws.pkl"

const type = "AWS::EC2::DHCPOptions"

open class DHCPOptionsResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden dhcpOptionsId: DHCPOptionsResolvable = (this) {
        property = "DhcpOptionsId"
    }
}

@aws.ResourceHint {
    type = module.type
    identifier = "DhcpOptionsId"
}
open class DHCPOptions extends formae.Resource {

    @aws.FieldHint{createOnly = true}
    domainName: String?

    @aws.FieldHint{createOnly = true; hasProviderDefault = true}
    domainNameServers: Listing<String>?

    @aws.FieldHint{createOnly = true}
    ipv6AddressPreferredLeaseTime: Int?

    @aws.FieldHint{createOnly = true; hasProviderDefault = true}
    netbiosNameServers: Listing<String>?

    @aws.FieldHint{createOnly = true}
    netbiosNodeType: Int?

    @aws.FieldHint{createOnly = true; hasProviderDefault = true}
    ntpServers: Listing<String>?

    @aws.FieldHint {
        updateMethod = "EntitySet"
        indexField = "Key"
    }
    tags: Listing<aws.Tag>?

    local parent = this

    hidden res: DHCPOptionsResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
