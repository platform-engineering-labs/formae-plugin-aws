module aws.ec2.transitgatewayattachment

import "@formae/formae.pkl"
import "../aws.pkl"

const type = "AWS::EC2::TransitGatewayAttachment"

open class TransitGatewayAttachmentResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden id: TransitGatewayAttachmentResolvable = (this) {
        property = "Id"
    }
}

@aws.ResourceHint {
    type = module.type
    identifier = "Id"
}
open class TransitGatewayAttachment extends formae.Resource {

    @aws.FieldHint
    options: Dynamic?

    @aws.FieldHint
    subnetIds: Listing<String|formae.Resolvable>

    @aws.FieldHint {
        updateMethod = "EntitySet"
        indexField = "Key"
    }
    tags: Listing<aws.Tag>?

    @aws.FieldHint{createOnly = true}
    transitGatewayId: String|formae.Resolvable

    @aws.FieldHint{createOnly = true}
    vpcId: String|formae.Resolvable

    local parent = this

    hidden res: TransitGatewayAttachmentResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
