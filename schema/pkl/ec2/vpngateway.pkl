module aws.ec2.vpngateway

import "@formae/formae.pkl"
import "../aws.pkl"

const type = "AWS::EC2::VPNGateway"

open class VPNGatewayResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden vpnGatewayId: VPNGatewayResolvable = (this) {
        property = "VPNGatewayId"
    }
}

@aws.ResourceHint {
    type = module.type
    identifier = "VPNGatewayId"
}
open class VPNGateway extends formae.Resource {

    @aws.FieldHint {
        createOnly = true
        hasProviderDefault = true
    }
    amazonSideAsn: (Int|formae.Resolvable)?

    @aws.FieldHint {
        updateMethod = "EntitySet"
        indexField = "Key"
    }
    tags: Listing<aws.Tag>?

    @aws.FieldHint{createOnly = true}
    type: String

    local parent = this

    hidden res: VPNGatewayResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
