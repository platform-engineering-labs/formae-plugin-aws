module aws.ec2.vpcendpointservice

import "@formae/formae.pkl"
import "../aws.pkl"

const type = "AWS::EC2::VPCEndpointService"

open class VPCEndpointServiceResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden serviceId: VPCEndpointServiceResolvable = (this) {
        property = "ServiceId"
    }
}

@aws.ResourceHint {
    type = module.type
    identifier = "ServiceId"
}
open class VPCEndpointService extends formae.Resource {

    @aws.FieldHint
    acceptanceRequired: Boolean?

    @aws.FieldHint{writeOnly = true}
    contributorInsightsEnabled: Boolean?

    @aws.FieldHint
    gatewayLoadBalancerArns: Listing<String|formae.Resolvable>?

    @aws.FieldHint
    networkLoadBalancerArns: Listing<String|formae.Resolvable>?

    @aws.FieldHint
    payerResponsibility: String?

    @aws.FieldHint {
        updateMethod = "EntitySet"
        indexField = "Key"
    }
    tags: Listing<aws.Tag>?

    local parent = this

    hidden res: VPCEndpointServiceResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
