module aws.ec2.ipam

import "@formae/formae.pkl"
import "../aws.pkl"

const type = "AWS::EC2::IPAM"

typealias IPAMTier = "free"|"advanced"

open class IPAMResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden ipamId: IPAMResolvable = (this) {
        property = "IpamId"
    }
    hidden privateDefaultScopeId: IPAMResolvable = (this) {
        property = "PrivateDefaultScopeId"
    }
    hidden publicDefaultScopeId: IPAMResolvable = (this) {
        property = "PublicDefaultScopeId"
    }
}

@aws.SubResourceHint
open class IPAMIpamOperatingRegion extends formae.SubResource {
    regionName: aws.Region
}

@aws.ResourceHint {
    type = module.type
    identifier = "IpamId"
}
open class IPAM extends formae.Resource {

    @aws.FieldHint
    description: String?

    @aws.FieldHint
    enablePrivateGua: Boolean?

    @aws.FieldHint
    operatingRegions: Listing<IPAMIpamOperatingRegion>?

    @aws.FieldHint {
        updateMethod = "EntitySet"
        indexField = "Key"
    }
    tags: Listing<aws.Tag>?

    @aws.FieldHint
    tier: IPAMTier?

    local parent = this

    hidden res: IPAMResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}