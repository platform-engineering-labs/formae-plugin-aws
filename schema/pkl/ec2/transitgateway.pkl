module aws.ec2.transitgateway

import "@formae/formae.pkl"
import "../aws.pkl"

const type = "AWS::EC2::TransitGateway"

open class TransitGatewayResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden id: TransitGatewayResolvable = (this) {
        property = "Id"
    }

    hidden transitGatewayArn: TransitGatewayResolvable = (this) {
        property = "TransitGatewayArn"
    }
}

@aws.ResourceHint {
    type = module.type
    identifier = "Id"
}
open class TransitGateway extends formae.Resource {

    @aws.FieldHint{createOnly = true}
    amazonSideAsn: Int?

    @aws.FieldHint
    associationDefaultRouteTableId: (String|formae.Resolvable)?

    @aws.FieldHint
    autoAcceptSharedAttachments: String?

    @aws.FieldHint
    defaultRouteTableAssociation: String?

    @aws.FieldHint
    defaultRouteTablePropagation: String?

    @aws.FieldHint
    description: String?

    @aws.FieldHint
    dnsSupport: String?

    @aws.FieldHint{createOnly = true}
    multicastSupport: String?

    @aws.FieldHint
    propagationDefaultRouteTableId: (String|formae.Resolvable)?

    @aws.FieldHint
    securityGroupReferencingSupport: String?

    @aws.FieldHint {
        updateMethod = "EntitySet"
        indexField = "Key"
    }
    tags: Listing<aws.Tag>?

    @aws.FieldHint
    transitGatewayCidrBlocks: Listing<String>?

    @aws.FieldHint
    vpnEcmpSupport: String?

    local parent = this

    hidden res: TransitGatewayResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}