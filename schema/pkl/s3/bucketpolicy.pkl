module aws.s3.bucketpolicy

import "../aws.pkl"
import "@formae/formae.pkl"

const type = "AWS::S3::BucketPolicy"

open class BucketPolicyResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden bucket: BucketPolicyResolvable = (this) {
        property = "Bucket"
    }
}

@aws.ResourceHint {
    type = module.type
    identifier = "Bucket"
}
open class BucketPolicy extends formae.Resource {
    @aws.FieldHint { createOnly = true }
    bucket: String|formae.Resolvable

    @aws.FieldHint
    policyDocument: Dynamic

    local parent = this

    hidden res: BucketPolicyResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
