module aws.iam.group

import "@formae/formae.pkl"
import "../aws.pkl"

const type = "AWS::IAM::Group"

@aws.SubResourceHint
open class GroupPolicy extends formae.SubResource {
    policyDocument: Dynamic
    policyName: String
}

open class GroupResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden arn: GroupResolvable = (this) {
        property = "Arn"
    }

    hidden groupName: GroupResolvable = (this) {
        property = "GroupName"
    }
}

@aws.ResourceHint {
    type = module.type
    identifier = "GroupName"
}
open class Group extends formae.Resource {

    @aws.FieldHint{createOnly = true}
    groupName: String?

    @aws.FieldHint
    managedPolicyArns: Listing<String>?

    @aws.FieldHint
    path: String?

    @aws.FieldHint
    policies: Listing<GroupPolicy>?

    hidden parent = this

    hidden res: GroupResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
