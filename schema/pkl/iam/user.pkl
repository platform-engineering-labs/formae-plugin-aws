module aws.iam.user

import "@formae/formae.pkl"
import "../aws.pkl"

const type = "AWS::IAM::User"

@aws.SubResourceHint
open class UserLoginProfile extends formae.SubResource {
    @aws.FieldHint{writeOnly = true}
    password: (String|formae.Value)?
    passwordResetRequired: Boolean?
}

@aws.SubResourceHint
open class UserPolicy extends formae.SubResource {
    policyDocument: Dynamic
    policyName: String
}

open class UserResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden arn: UserResolvable = (this) {
        property = "Arn"
    }

    hidden userName: UserResolvable = (this) {
        property = "UserName"
    }
}

@aws.ResourceHint {
    type = module.type
    identifier = "UserName"
    discoverable = false
    extractable = false
}
open class User extends formae.Resource {

    @aws.FieldHint{hasProviderDefault = true}
    groups: Listing<String|formae.Resolvable>?

    @aws.FieldHint
    loginProfile: UserLoginProfile?

    @aws.FieldHint{hasProviderDefault = true}
    managedPolicyArns: Listing<String|formae.Resolvable>?

    @aws.FieldHint{hasProviderDefault = true}
    path: String?

    @aws.FieldHint
    permissionsBoundary: String?

    @aws.FieldHint
    policies: Listing<UserPolicy>?

    @aws.FieldHint {
        hasProviderDefault = true
        updateMethod = "EntitySet"
        indexField = "Key"
    }
    tags: Listing<aws.Tag>?

    @aws.FieldHint{createOnly = true}
    userName: String?

    hidden parent = this

    hidden res: UserResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
