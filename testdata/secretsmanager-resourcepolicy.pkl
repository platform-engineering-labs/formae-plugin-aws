amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/secretsmanager/secret.pkl"
import "@aws/secretsmanager/resourcepolicy.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-secretsmanager-resourcepolicy-\(testRunID)"

// Secret dependency - ResourcePolicy needs a secret to attach to
local testSecret = new secret.Secret {
  label = "test-secret"
  name = "formae-plugin-sdk-test-rp-\(testRunID)"
  description = "SDK test secret for ResourcePolicy"
}

// Second secret - created upfront so the replace fixture can swap without adding resources
local testSecret2 = new secret.Secret {
  label = "test-secret-2"
  name = "formae-plugin-sdk-test-rp-2-\(testRunID)"
  description = "SDK test secret 2 for ResourcePolicy"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for SecretsManager ResourcePolicy"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // Both secrets created upfront for replace test
  testSecret
  testSecret2

  // ResourcePolicy under test
  new resourcepolicy.ResourcePolicy {
    label = "plugin-sdk-test-resourcepolicy"
    secretId = testSecret.res.name
    blockPublicPolicy = false
    resourcePolicy {
      ["Version"] = "2012-10-17"
      ["Statement"] {
        new {
          ["Effect"] = "Allow"
          ["Principal"] {
            ["AWS"] = "*"
          }
          ["Action"] = "secretsmanager:GetSecretValue"
          ["Resource"] = "*"
        }
      }
    }
  }
}
