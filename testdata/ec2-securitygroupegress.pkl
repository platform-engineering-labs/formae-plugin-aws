amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/vpc.pkl"
import "@aws/ec2/securitygroup.pkl"
import "@aws/ec2/securitygroupegress.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-securitygroupegress-\(testRunID)"

// VPC dependency
local testVpc = new vpc.VPC {
  label = "test-vpc-for-sgegress"
  cidrBlock = "10.0.0.0/16"
  enableDnsSupport = true
}

// SecurityGroup dependency
local testSg = new securitygroup.SecurityGroup {
  label = "test-sg-for-sgegress"
  groupDescription = "Test security group for egress rule"
  groupName = "formae-sdk-test-sg-egress-\(testRunID)"
  vpcId = testVpc.res.vpcId
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 SecurityGroupEgress"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // VPC required for SecurityGroup
  testVpc

  // SecurityGroup required for Egress rule
  testSg

  // SecurityGroupEgress under test
  new securitygroupegress.SecurityGroupEgress {
    label = "plugin-sdk-test-sgegress"
    groupId = testSg.res.groupId
    ipProtocol = "tcp"
    fromPort = 443
    toPort = 443
    cidrIp = "0.0.0.0/0"
  }
}
