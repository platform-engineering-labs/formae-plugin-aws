amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/s3/bucket.pkl"
import "@aws/s3/object.pkl"

// Read the test run ID from environment variable set by the test harness
// This ensures consistent naming within a test run but unique names between runs
local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-s3-object-inline-\(testRunID)"

local myBucket = new bucket.Bucket {
  label = "s3-object-inline-test-bucket"
  bucketName = "formae-plugin-sdk-test-objinl-\(testRunID)"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for S3 Object (inline content + optional attributes)"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  myBucket

  // Exercises the inline `content` source and the shared optional-attribute
  // path (cacheControl, contentDisposition, metadata). Metadata keys are
  // lowercase because S3 lowercases user metadata on read.
  new object.Object {
    label = "plugin-sdk-test-inline-object"
    bucket = myBucket.res.bucketName
    key = "test-artifacts/inline.txt"
    content = "hello from formae"
    contentType = "text/plain"
    cacheControl = "max-age=300"
    contentDisposition = "inline"
    metadata {
      ["env"] = "test"
    }
    tags {
      new { key = "Name"; value = "inline-object" }
      new { key = "Environment"; value = "test" }
    }
  }
}
