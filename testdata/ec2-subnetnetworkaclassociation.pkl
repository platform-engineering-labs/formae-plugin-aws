amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/vpc.pkl"
import "@aws/ec2/subnet.pkl"
import "@aws/ec2/networkacl.pkl"
import "@aws/ec2/subnetnetworkaclassociation.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-subnetnetworkaclassociation-\(testRunID)"

// VPC dependency
local testVpc = new vpc.VPC {
  label = "test-vpc-for-snaclassoc"
  cidrBlock = "10.0.0.0/16"
  enableDnsSupport = true
}

// Subnet dependency
local testSubnet = new subnet.Subnet {
  label = "test-subnet-for-snaclassoc"
  vpcId = testVpc.res.vpcId
  cidrBlock = "10.0.1.0/24"
  availabilityZone = "us-east-1a"
}

// NetworkAcl dependency
local testNetworkAcl = new networkacl.NetworkAcl {
  label = "test-networkacl-for-snaclassoc"
  vpcId = testVpc.res.vpcId
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 SubnetNetworkAclAssociation"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // VPC required
  testVpc

  // Subnet required
  testSubnet

  // NetworkAcl required
  testNetworkAcl

  // SubnetNetworkAclAssociation under test
  new subnetnetworkaclassociation.SubnetNetworkAclAssociation {
    label = "plugin-sdk-test-subnetnetworkaclassociation"
    subnetId = testSubnet.res.subnetId
    networkAclId = testNetworkAcl.res.id
  }
}
