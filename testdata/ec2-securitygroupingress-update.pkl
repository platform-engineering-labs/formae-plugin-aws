amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/vpc.pkl"
import "@aws/ec2/securitygroup.pkl"
import "@aws/ec2/securitygroupingress.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-securitygroupingress-\(testRunID)"

// VPC dependency
local testVpc = new vpc.VPC {
  label = "test-vpc-for-sgingress"
  cidrBlock = "10.0.0.0/16"
  enableDnsSupport = true
}

// SecurityGroup dependency
local testSg = new securitygroup.SecurityGroup {
  label = "test-sg-for-sgingress"
  groupDescription = "Test security group for ingress rule"
  groupName = "formae-sdk-test-sg-ingress-\(testRunID)"
  vpcId = testVpc.res.vpcId
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 SecurityGroupIngress"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // VPC required for SecurityGroup
  testVpc

  // SecurityGroup required for Ingress rule
  testSg

  // SecurityGroupIngress under test - updated description
  new securitygroupingress.SecurityGroupIngress {
    label = "plugin-sdk-test-sgingress"
    groupId = testSg.res.groupId
    ipProtocol = "tcp"
    fromPort = 80
    toPort = 80
    cidrIp = "10.0.0.0/8"
    description = "Allow HTTP from internal network"
  }
}
