amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/iam/role.pkl"
import "@aws/iam/policy.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-iam-policy-\(testRunID)"

local testRole = new role.Role {
  label = "test-role"
  roleName = "formae-sdk-test-policy-role-\(testRunID)"
  assumeRolePolicyDocument {
    ["Version"] = "2012-10-17"
    ["Statement"] {
      new {
        ["Effect"] = "Allow"
        ["Principal"] {
          ["Service"] = "lambda.amazonaws.com"
        }
        ["Action"] = "sts:AssumeRole"
      }
    }
  }
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for IAM Policy"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  testRole

  // Updated: change policy document to add more actions
  new policy.Policy {
    label = "plugin-sdk-test-policy"
    policyName = "formae-sdk-test-policy-\(testRunID)"
    roles {
      testRole.res.roleName
    }
    policyDocument {
      ["Version"] = "2012-10-17"
      ["Statement"] {
        new {
          ["Effect"] = "Allow"
          ["Action"] = "logs:*"
          ["Resource"] = "*"
        }
      }
    }
  }
}
