amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/sqs/queue.pkl"
import "@aws/sqs/queuepolicy.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-sqs-queuepolicy-\(testRunID)"

local testQueue = new queue.Queue {
  label = "test-queue"
  queueName = "formae-sdk-test-qp-queue-\(testRunID)"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for SQS QueuePolicy"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  testQueue

  // Updated: change policy to Deny
  new queuepolicy.QueuePolicy {
    label = "plugin-sdk-test-queuepolicy"
    queues {
      testQueue.res.queueUrl
    }
    policyDocument {
      ["Version"] = "2012-10-17"
      ["Statement"] {
        new {
          ["Sid"] = "DenySendMessage"
          ["Effect"] = "Deny"
          ["Principal"] {
            ["AWS"] = "*"
          }
          ["Action"] = "sqs:SendMessage"
          ["Resource"] = testQueue.res.arn
        }
      }
    }
  }
}
