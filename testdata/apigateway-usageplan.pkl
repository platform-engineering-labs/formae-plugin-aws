amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/apigateway/usageplan.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-apigateway-usageplan-\(testRunID)"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for ApiGateway UsagePlan"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  new usageplan.UsagePlan {
    label = "plugin-sdk-test-usageplan"
    usagePlanName = "formae-sdk-test-usageplan-\(testRunID)"
    description = "Test usage plan"
    throttle = new usageplan.ThrottleSettings {
      burstLimit = 100
      rateLimit = 50.0
    }
  }
}
