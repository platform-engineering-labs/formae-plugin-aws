amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/prefixlist.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-prefixlist-\(testRunID)"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 PrefixList"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // PrefixList under test - update adds a third entry to the managed list
  new prefixlist.PrefixList {
    label = "plugin-sdk-test-prefixlist"
    addressFamily = "IPv4"
    prefixListName = "formae-sdk-test-pl-\(testRunID)"
    maxEntries = 10
    entries {
      new {
        cidr = "10.0.0.0/16"
        description = "primary range"
      }
      new {
        cidr = "10.1.0.0/16"
        description = "secondary range"
      }
      new {
        cidr = "10.2.0.0/16"
        description = "tertiary range"
      }
    }
    tags {
      new { key = "Name"; value = "formae-plugin-sdk-test-prefixlist-\(testRunID)" }
    }
  }
}
