amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/cloudfront/responseheaderspolicy.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-cloudfront-responseheaderspolicy-\(testRunID)"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for CloudFront ResponseHeadersPolicy"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  new responseheaderspolicy.ResponseHeadersPolicy {
    label = "plugin-sdk-test-rhp"
    responseHeadersPolicyConfig = new responseheaderspolicy.ResponseHeadersPolicyConfig {
      name = "formae-plugin-sdk-test-rhp-\(testRunID)"
      comment = "Plugin SDK test ResponseHeadersPolicy"
      customHeadersConfig = new responseheaderspolicy.CustomHeadersConfig {
        items = new Listing<responseheaderspolicy.CustomHeader> {
          new {
            header = "X-Formae-Test"
            value = "initial"
            `override` = true
          }
        }
      }
    }
  }
}
