amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/iam/role.pkl"
import "@aws/lambda/func.pkl"
import "@aws/lambda/lambdaalias.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-lambda-alias-\(testRunID)"

local lambdaRole = new role.Role {
  label = "lambda-execution-role"
  roleName = "formae-sdk-test-lambda-alias-role-\(testRunID)"
  assumeRolePolicyDocument {
    ["Version"] = "2012-10-17"
    ["Statement"] {
      new {
        ["Effect"] = "Allow"
        ["Principal"] {
          ["Service"] = "lambda.amazonaws.com"
        }
        ["Action"] = "sts:AssumeRole"
      }
    }
  }
}

local testFunction = new func.Function {
  label = "test-function-for-alias"
  functionName = "formae-sdk-test-lambda-alias-\(testRunID)"
  role = lambdaRole.res.arn
  runtime = "python3.12"
  handler = "index.handler"
  code = new func.Code {
    zipFile = """
      import json
      def handler(event, context):
          return {
              'statusCode': 200,
              'body': json.dumps({'message': 'hello from formae'})
          }
      """
  }
  memorySize = 128
  timeout = 10
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Lambda Alias"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  lambdaRole

  testFunction

  new lambdaalias.Alias {
    label = "plugin-sdk-test-lambda-alias"
    functionName = testFunction.res.arn
    name = "test-alias"
    functionVersion = "$LATEST"
    description = "Formae SDK test alias - updated"
  }
}
