amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/vpc.pkl"
import "@aws/ec2/vpcendpoint.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-vpcendpoint-\(testRunID)"

// VPC dependency
local testVpc = new vpc.VPC {
  label = "test-vpc-for-vpce"
  cidrBlock = "10.222.0.0/16"
  enableDnsSupport = true
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 VPCEndpoint"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // VPC required for VPC Endpoint
  testVpc

  // VPC Endpoint under test - updated: enable DNS support
  // Note: PolicyDocument updates cause mismatch because AWS adds a default statement
  new vpcendpoint.VPCEndpoint {
    label = "plugin-sdk-test-vpce"
    vpcId = testVpc.res.vpcId
    serviceName = "com.amazonaws.us-east-1.s3"
    vpcEndpointType = "Gateway"
    privateDnsEnabled = false
  }
}
