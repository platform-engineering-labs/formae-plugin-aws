amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/iam/role.pkl"
import "@aws/secretsmanager/secret.pkl"
import "@aws/ecs/taskdefinition.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ecs-taskdefinition-secret-arn-\(testRunID)"

// From-scratch Secret whose ARN the task definition references via
// `dbSecret.res.arn`. The value is a raw generated string (passwordLength, no
// secretStringTemplate/generateStringKey): a JSON secret injected via
// `valueFrom = arn` would deliver the whole blob, and selecting one key would
// require an `<arn>:key::` suffix. The ARN is unknown until the secret is
// created, so it resolves at apply time, after which the task definition can
// reference it without the password ever appearing in plaintext.
local dbSecret = new secret.Secret {
  label = "test-secret-for-ecs-taskdef-arn"
  name = "formae-plugin-sdk-test-ecs-td-secret-\(testRunID)"
  description = "Secret whose ARN is referenced by an ECS task definition via dbSecret.res.arn"
  generateSecretString = new secret.GenerateSecretString {
    passwordLength = 20
    excludePunctuation = true
  }
}

// ECS requires an execution role when a container pulls a value from `secrets`;
// it must trust `ecs-tasks.amazonaws.com` (not lambda). Its ARN is referenced
// via `executionRole.res.arn`.
local executionRole = new role.Role {
  label = "test-execution-role-for-ecs-taskdef-arn"
  roleName = "formae-plugin-sdk-test-ecs-td-exec-role-\(testRunID)"
  assumeRolePolicyDocument {
    ["Version"] = "2012-10-17"
    ["Statement"] {
      new {
        ["Effect"] = "Allow"
        ["Principal"] {
          ["Service"] = "ecs-tasks.amazonaws.com"
        }
        ["Action"] = "sts:AssumeRole"
      }
    }
  }
}

local testTaskDef = new taskdefinition.TaskDefinition {
  label = "plugin-sdk-test-ecs-taskdefinition-secret-arn"
  family = "formae-sdk-test-td-secret-arn-\(testRunID)"
  requiresCompatibilities {
    "FARGATE"
  }
  networkMode = "awsvpc"
  cpu = "256"
  memory = "512"
  executionRoleArn = executionRole.res.arn
  // AWS returns Tags as [] when unset. The conformance harness's reverse loop
  // flags "extra" actual fields not in expected and not marked as
  // hasProviderDefault. Set explicitly so the harness sees Tags as "in
  // expected" and skips the check. Tags is user-canonical so we don't want
  // hasProviderDefault on the schema (would silently drop user changes).
  tags = new Listing<aws.Tag> {}
  containerDefinitions {
    new {
      name = "test-container"
      image = "nginx:latest"
      essential = true
      // The container pulls the DB password from Secrets Manager at task start
      // via the resolved secret ARN; the password is never declared inline.
      secrets {
        new {
          name = "FORMAE_DB_PASSWORD"
          valueFrom = dbSecret.res.arn
        }
      }
      // AWS returns these container fields as [] / {} when unset. Same harness
      // reason as Tags above. Schema deliberately omits hasProviderDefault on
      // them because they are user-canonical and the strip would silently drop
      // user changes.
      command = new Listing<String> {}
      credentialSpecs = new Listing<String> {}
      dependsOn = new Listing<taskdefinition.ContainerDependency> {}
      dnsSearchDomains = new Listing<String> {}
      dnsServers = new Listing<String> {}
      dockerLabels = new Mapping<String, Any> {}
      dockerSecurityOptions = new Listing<String> {}
      entryPoint = new Listing<String> {}
      environment = new Listing<taskdefinition.KeyValuePair> {}
      environmentFiles = new Listing<taskdefinition.EnvironmentFile> {}
      extraHosts = new Listing<taskdefinition.HostEntry> {}
      links = new Listing<String> {}
      mountPoints = new Listing<taskdefinition.MountPoint> {}
      portMappings = new Listing<taskdefinition.PortMapping> {}
      resourceRequirements = new Listing<taskdefinition.ResourceRequirement> {}
      systemControls = new Listing<taskdefinition.SystemControl> {}
      ulimits = new Listing<taskdefinition.Ulimit> {}
      volumesFrom = new Listing<taskdefinition.VolumeFrom> {}
    }
  }
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for resolving a Secret ARN (dbSecret.res.arn) in an ECS TaskDefinition container's secrets[].valueFrom"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  dbSecret
  executionRole

  // TaskDefinition under test, declared last: the conformance harness's
  // findTargetResource falls back to the last resource. It is a singleton of
  // its type and a deletable leaf (nothing references it).
  testTaskDef
}
