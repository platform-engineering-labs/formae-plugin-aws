amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/vpc.pkl"
import "@aws/ec2/subnet.pkl"
import "@aws/ec2/routetable.pkl"
import "@aws/ec2/subnetroutetableassociation.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-subnetroutetableassociation-\(testRunID)"

// VPC dependency
local testVpc = new vpc.VPC {
  label = "test-vpc-for-srtassoc"
  cidrBlock = "10.0.0.0/16"
  enableDnsSupport = true
}

// Subnet dependency
local testSubnet = new subnet.Subnet {
  label = "test-subnet-for-srtassoc"
  vpcId = testVpc.res.vpcId
  cidrBlock = "10.0.1.0/24"
  availabilityZone = "us-east-1a"
}

// RouteTable dependency
local testRouteTable = new routetable.RouteTable {
  label = "test-routetable-for-srtassoc"
  vpcId = testVpc.res.vpcId
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 SubnetRouteTableAssociation"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // VPC required for Subnet and RouteTable
  testVpc

  // Subnet required for association
  testSubnet

  // RouteTable required for association
  testRouteTable

  // SubnetRouteTableAssociation under test
  new subnetroutetableassociation.SubnetRouteTableAssociation {
    label = "plugin-sdk-test-srtassoc"
    subnetId = testSubnet.res.subnetId
    routeTableId = testRouteTable.res.routeTableId
  }
}
