amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/iam/role.pkl"
import "@aws/ec2/vpc.pkl"
import "@aws/ec2/subnet.pkl"
import "@aws/eks/ekscluster.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-eks-cluster-\(testRunID)"

// IAM Role for EKS cluster
local testRole = new role.Role {
  label = "test-role-for-eks"
  roleName = "formae-sdk-test-eks-role-\(testRunID)"
  assumeRolePolicyDocument {
    ["Version"] = "2012-10-17"
    ["Statement"] {
      new {
        ["Effect"] = "Allow"
        ["Principal"] {
          ["Service"] = "eks.amazonaws.com"
        }
        ["Action"] = "sts:AssumeRole"
      }
    }
  }
  managedPolicyArns {
    "arn:aws:iam::aws:policy/AmazonEKSClusterPolicy"
  }
}

// VPC dependency
local testVpc = new vpc.VPC {
  label = "test-vpc-for-eks"
  cidrBlock = "10.230.0.0/16"
  enableDnsSupport = true
  enableDnsHostnames = true
}

// Two subnets in different AZs required for EKS
local testSubnet1 = new subnet.Subnet {
  label = "test-subnet-1-for-eks"
  vpcId = testVpc.res.vpcId
  cidrBlock = "10.230.1.0/24"
  availabilityZone = "us-east-1a"
}

local testSubnet2 = new subnet.Subnet {
  label = "test-subnet-2-for-eks"
  vpcId = testVpc.res.vpcId
  cidrBlock = "10.230.2.0/24"
  availabilityZone = "us-east-1b"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EKS Cluster"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // IAM Role required for EKS cluster
  testRole

  // VPC required for EKS cluster
  testVpc

  // Subnets required for EKS cluster (minimum 2 AZs)
  testSubnet1
  testSubnet2

  // EKS Cluster under test
  new ekscluster.Cluster {
    label = "plugin-sdk-test-eks"
    name = "formae-sdk-test-eks-\(testRunID)"
    roleArn = testRole.res.arn
    version = "1.29"
    resourcesVpcConfig = new {
      subnetIds {
        testSubnet1.res.subnetId
        testSubnet2.res.subnetId
      }
      endpointPublicAccess = true
    }
  }
}
