amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ses/emailidentity.pkl"
import "@aws/ses/emailidentityverification.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ses-emailidentityverification-\(testRunID)"

// EmailIdentity dependency — verification gates on the identity
local parentIdentity = new emailidentity.EmailIdentity {
  label = "id-for-verification"
  emailIdentity = "formae-conformance-v-\(testRunID).example.com"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for SES EmailIdentityVerification"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // Parent EmailIdentity
  parentIdentity

  // EmailIdentityVerification under test
  new emailidentityverification.EmailIdentityVerification {
    label = "primary-verification"
    identity = parentIdentity.res.emailIdentity
  }
}
