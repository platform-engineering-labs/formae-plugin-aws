amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/ipam.pkl"
import "@aws/ec2/ipamscope.pkl"
import "@aws/ec2/ipampool.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-ipampool-\(testRunID)"

local testIpam = new ipam.IPAM {
  label = "test-ipam-for-pool"
  description = "IPAM for IPAMPool test"
  operatingRegions {
    new { regionName = "us-east-1" }
  }
  tags {
    new { key = "Name"; value = "formae-plugin-sdk-test-ipam-for-pool-\(testRunID)" }
  }
}

local testScope = new ipamscope.IPAMScope {
  label = "test-scope-for-pool"
  ipamId = testIpam.res.ipamId
  description = "Scope for IPAMPool test"
  tags {
    new { key = "Name"; value = "formae-plugin-sdk-test-scope-for-pool-\(testRunID)" }
  }
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 IPAMPool"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // IPAM + scope required for the pool
  testIpam
  testScope

  // IPAMPool under test
  new ipampool.IPAMPool {
    label = "plugin-sdk-test-ipampool"
    addressFamily = "ipv4"
    ipamScopeId = testScope.res.ipamScopeId
    locale = "us-east-1"
    description = "Plugin SDK test IPAM pool"
    tags {
      new { key = "Name"; value = "formae-plugin-sdk-test-ipampool-\(testRunID)" }
    }
  }
}
