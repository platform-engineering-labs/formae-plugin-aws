amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/cloudfront/originaccesscontrol.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-cloudfront-originaccesscontrol-\(testRunID)"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for CloudFront OriginAccessControl"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  new originaccesscontrol.OriginAccessControl {
    label = "plugin-sdk-test-oac"
    originAccessControlConfig = new originaccesscontrol.OriginAccessControlConfig {
      name = "formae-plugin-sdk-test-oac-\(testRunID)"
      description = "Plugin SDK test OAC"
      originAccessControlOriginType = "s3"
      signingBehavior = "always"
      signingProtocol = "sigv4"
    }
  }
}
