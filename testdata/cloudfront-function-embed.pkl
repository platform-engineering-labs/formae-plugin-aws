// Conformance fixture for PLA-68: an embedded resolvable inside a String field.
// The Function's functionCode is a cf-js-2.0 literal that calls cf.kvs('<id>')
// with the KeyValueStore's CloudFront-generated short Id embedded in the source
// via formae.embed(...). This exercises single-apply resolution of an embedded
// resolvable (functionCode) alongside a whole-value resolvable (the KVS ARN
// association). Pre-PLA-68 this required a two-apply manual-substitution.

amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/cloudfront/cffunction.pkl" as cffn
import "@aws/cloudfront/keyvaluestore.pkl" as kvsmod

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-cloudfront-function-embed-\(testRunID)"

local kvStore = new kvsmod.KeyValueStore {
  label = "plugin-sdk-test-embed-kvs"
  stack = new formae.StackResolvable { label = stackName }
  name = "formae-plugin-sdk-test-kvs-\(testRunID)"
  comment = "Plugin SDK test KVS for embedded-resolvable Function"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for embedded-resolvable CloudFront Function"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  kvStore

  new cffn.Function {
    label = "plugin-sdk-test-embed-fn"
    stack = new formae.StackResolvable { label = stackName }
    name = "formae-plugin-sdk-test-embed-fn-\(testRunID)"
    autoPublish = true
    // The embedded resolvable: the KVS short Id is substituted into the JS
    // literal at resolve time, so this ships as a plain String to CloudFront.
    functionCode = formae.embed("""
      import cf from 'cloudfront';
      const kvsId = '\(kvStore.res.id)';
      async function handler(event) {
        const kvs = cf.kvs(kvsId);
        return event.request;
      }
      """)
    functionConfig = new cffn.FunctionConfig {
      runtime = "cloudfront-js-2.0"
      comment = "Plugin SDK test Function (embedded resolvable)"
      keyValueStoreAssociations = new Listing {
        new cffn.KeyValueStoreAssociation {
          keyValueStoreARN = kvStore.res.arn
        }
      }
    }
  }
}
