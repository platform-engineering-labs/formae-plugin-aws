amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/apigateway/restapi.pkl"
import "@aws/apigateway/resource.pkl"
import "@aws/apigateway/method.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-apigateway-method-\(testRunID)"

// RestApi dependency - same as create
local testApi = new restapi.RestApi {
  label = "test-restapi-for-method"
  name = "formae-sdk-test-meth-api-\(testRunID)"
  description = "Test API for Method"
  endpointConfiguration = new restapi.EndpointConfiguration {
    types = new Listing { "REGIONAL" }
  }
}

// Resource dependency - same as create
local testResource = new resource.Resource {
  label = "test-resource-for-method"
  restApiId = testApi.res.restApiId
  parentId = testApi.res.rootResourceId
  pathPart = "test"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for ApiGateway Method"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // Parent RestApi
  testApi

  // Parent Resource
  testResource

  // Updated: added operationName
  new method.Method {
    label = "plugin-sdk-test-method"
    restApiId = testApi.res.restApiId
    resourceId = testResource.res.resourceId
    httpMethod = "GET"
    authorizationType = "NONE"
    operationName = "testGetOperation"
    integration = new method.Integration {
      type = "MOCK"
      requestTemplates {
        ["application/json"] = "{\"statusCode\": 200}"
      }
      integrationResponses {
        new {
          statusCode = "200"
          responseTemplates {
            ["application/json"] = "{}"
          }
        }
      }
    }
    methodResponses {
      new {
        statusCode = "200"
      }
    }
  }
}
