amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/efs/filesystem.pkl"
import "@aws/efs/accesspoint.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-efs-accesspoint-\(testRunID)"

// FileSystem dependency
local testFs = new filesystem.FileSystem {
  label = "test-fs-for-accesspoint"
  encrypted = true
  performanceMode = "generalPurpose"
  throughputMode = "bursting"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EFS AccessPoint"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // FileSystem required for AccessPoint
  testFs

  // AccessPoint under test
  new accesspoint.AccessPoint {
    label = "plugin-sdk-test-accesspoint"
    fileSystemId = testFs.res.fileSystemId
    posixUser = new {
      uid = "1000"
      gid = "1000"
    }
    rootDirectory = new {
      path = "/test"
      creationInfo = new {
        ownerUid = "1000"
        ownerGid = "1000"
        permissions = "755"
      }
    }
  }
}
