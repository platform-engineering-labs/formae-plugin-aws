amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/vpc.pkl"
import "@aws/ec2/vpcpeeringconnection.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-vpcpeeringconnection-\(testRunID)"

// Requester VPC
local testVpc = new vpc.VPC {
  label = "test-vpc-requester-for-peering"
  cidrBlock = "10.0.0.0/16"
  enableDnsSupport = true
}

// Accepter (peer) VPC - must use a non-overlapping CIDR
local testPeerVpc = new vpc.VPC {
  label = "test-vpc-accepter-for-peering"
  cidrBlock = "10.1.0.0/16"
  enableDnsSupport = true
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 VPCPeeringConnection"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // Both VPCs required for the peering connection
  testVpc
  testPeerVpc

  // VPCPeeringConnection under test (same account, same region - auto-accepts)
  new vpcpeeringconnection.VPCPeeringConnection {
    label = "plugin-sdk-test-vpcpeeringconnection"
    vpcId = testVpc.res.vpcId
    peerVpcId = testPeerVpc.res.vpcId
    tags {
      new { key = "Name"; value = "formae-plugin-sdk-test-vpcpeeringconnection-\(testRunID)" }
    }
  }
}
