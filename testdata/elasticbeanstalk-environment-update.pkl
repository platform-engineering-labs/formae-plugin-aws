amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/iam/role.pkl"
import "@aws/elasticbeanstalk/application.pkl"
import "@aws/elasticbeanstalk/environment.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-eb-environment-\(testRunID)"

// IAM Role dependency - same as create
local ebRole = new role.Role {
  label = "eb-service-role"
  roleName = "formae-sdk-test-eb-env-role-\(testRunID)"
  assumeRolePolicyDocument {
    ["Version"] = "2012-10-17"
    ["Statement"] {
      new {
        ["Effect"] = "Allow"
        ["Principal"] {
          ["Service"] = "elasticbeanstalk.amazonaws.com"
        }
        ["Action"] = "sts:AssumeRole"
      }
    }
  }
}

// EB Application (parent resource) - same as create
local ebApp = new application.Application {
  label = "plugin-sdk-test-eb-app"
  applicationName = "formae-sdk-test-env-app-\(testRunID)"
  description = "Formae SDK test application for Environment"
  resourceLifecycleConfig = new application.ResourceLifecycleConfig {
    serviceRole = ebRole.res.arn
    versionLifecycleConfig = new application.VersionLifecycleConfig {
      maxAgeRule = new application.MaxAgeRule {
        deleteSourceFromS3 = false
        enabled = false
        maxAgeInDays = 180
      }
      maxCountRule = new application.MaxCountRule {
        deleteSourceFromS3 = false
        enabled = false
        maxCount = 200
      }
    }
  }
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for ElasticBeanstalk Environment"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  ebRole

  ebApp

  // Updated: changed description
  new environment.Environment {
    label = "plugin-sdk-test-eb-env"
    applicationName = ebApp.res.applicationName
    environmentName = "formae-sdk-test-env-\(testRunID)"
    solutionStackName = "64bit Amazon Linux 2023 v4.4.4 running Docker"
    description = "Formae SDK test environment - updated"
    tier = new environment.Tier {
      name = "WebServer"
      type = "Standard"
    }
  }
}
