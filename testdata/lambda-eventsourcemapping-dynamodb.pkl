amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/iam/role.pkl"
import "@aws/lambda/func.pkl"
import "@aws/lambda/eventsourcemapping.pkl"
import "@aws/dynamodb/table.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-lambda-esm-dynamodb-\(testRunID)"

local lambdaRole = new role.Role {
  label = "lambda-execution-role"
  roleName = "formae-sdk-test-lambda-esm-ddb-role-\(testRunID)"
  assumeRolePolicyDocument {
    ["Version"] = "2012-10-17"
    ["Statement"] {
      new {
        ["Effect"] = "Allow"
        ["Principal"] {
          ["Service"] = "lambda.amazonaws.com"
        }
        ["Action"] = "sts:AssumeRole"
      }
    }
  }
  policies {
    new {
      policyName = "dynamodb-stream-access"
      policyDocument {
        ["Version"] = "2012-10-17"
        ["Statement"] {
          new {
            ["Effect"] = "Allow"
            ["Action"] {
              "dynamodb:GetRecords"
              "dynamodb:GetShardIterator"
              "dynamodb:DescribeStream"
              "dynamodb:ListStreams"
            }
            ["Resource"] = "*"
          }
        }
      }
    }
  }
}

local testFunction = new func.Function {
  label = "test-function-for-esm"
  functionName = "formae-sdk-test-lambda-esm-ddb-\(testRunID)"
  role = lambdaRole.res.arn
  runtime = "python3.12"
  handler = "index.handler"
  code = new func.Code {
    zipFile = """
      import json
      def handler(event, context):
          for record in event.get('Records', []):
              print(json.dumps(record))
          return {'statusCode': 200}
      """
  }
  memorySize = 128
  timeout = 10
}

local stateTable = new table.Table {
  label = "test-table-for-esm"
  tableName = "formae-plugin-sdk-test-esm-table-\(testRunID)"
  billingMode = "PAY_PER_REQUEST"
  keySchema {
    new {
      attributeName = "id"
      keyType = "HASH"
    }
  }
  attributeDefinitions {
    new {
      attributeName = "id"
      attributeType = "S"
    }
  }
  streamSpecification = new table.StreamSpecification {
    streamViewType = "NEW_AND_OLD_IMAGES"
  }
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Lambda EventSourceMapping wired to a DynamoDB stream"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  lambdaRole

  testFunction

  stateTable

  new eventsourcemapping.EventSourceMapping {
    label = "plugin-sdk-test-lambda-esm-dynamodb"
    functionName = testFunction.res.arn
    eventSourceArn = stateTable.res.streamArn
    startingPosition = "LATEST"
    batchSize = 10
    enabled = true
  }
}
