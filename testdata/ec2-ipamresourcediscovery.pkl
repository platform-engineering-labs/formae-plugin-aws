amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/ipamresourcediscovery.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-ipamresourcediscovery-\(testRunID)"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 IPAMResourceDiscovery"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  new ipamresourcediscovery.IPAMResourceDiscovery {
    label = "plugin-sdk-test-ipamresourcediscovery"
    description = "Plugin SDK test IPAM resource discovery"
    operatingRegions {
      new { regionName = "us-east-1" }
    }
    tags {
      new { key = "Name"; value = "formae-plugin-sdk-test-ipamresourcediscovery-\(testRunID)" }
    }
  }
}
