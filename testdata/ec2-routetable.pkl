amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/vpc.pkl"
import "@aws/ec2/routetable.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-routetable-\(testRunID)"

// VPC dependency - RouteTable needs a VPC
local testVpc = new vpc.VPC {
  label = "test-vpc-for-routetable"
  cidrBlock = "10.0.0.0/16"
  enableDnsSupport = true
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 RouteTable"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // VPC required for RouteTable
  testVpc

  // RouteTable under test
  new routetable.RouteTable {
    label = "plugin-sdk-test-routetable"
    vpcId = testVpc.res.vpcId
  }
}
