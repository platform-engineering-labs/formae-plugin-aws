amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/vpc.pkl"
import "@aws/ec2/subnet.pkl"
import "@aws/ec2/securitygroup.pkl"
import "@aws/efs/filesystem.pkl"
import "@aws/efs/mounttarget.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-efs-mounttarget-\(testRunID)"

// VPC dependency
local testVpc = new vpc.VPC {
  label = "test-vpc-for-mounttarget"
  cidrBlock = "10.227.0.0/16"
  enableDnsSupport = true
}

// Subnet dependency
local testSubnet = new subnet.Subnet {
  label = "test-subnet-for-mounttarget"
  vpcId = testVpc.res.vpcId
  cidrBlock = "10.227.1.0/24"
  availabilityZone = "us-east-1a"
}

// Security Group dependency
local testSg = new securitygroup.SecurityGroup {
  label = "test-sg-for-mounttarget"
  groupDescription = "Security group for EFS mount target test"
  groupName = "formae-sdk-test-mt-sg-\(testRunID)"
  vpcId = testVpc.res.vpcId
}

// FileSystem dependency
local testFs = new filesystem.FileSystem {
  label = "test-fs-for-mounttarget"
  encrypted = true
  performanceMode = "generalPurpose"
  throughputMode = "bursting"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EFS MountTarget"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // VPC required for MountTarget
  testVpc

  // Subnet required for MountTarget
  testSubnet

  // Security Group required for MountTarget
  testSg

  // FileSystem required for MountTarget
  testFs

  // MountTarget under test
  new mounttarget.MountTarget {
    label = "plugin-sdk-test-mounttarget"
    fileSystemId = testFs.res.fileSystemId
    subnetId = testSubnet.res.subnetId
    securityGroups {
      testSg.res.groupId
    }
  }
}
