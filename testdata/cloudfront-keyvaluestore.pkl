amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/cloudfront/keyvaluestore.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-cloudfront-keyvaluestore-\(testRunID)"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for CloudFront KeyValueStore"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  new keyvaluestore.KeyValueStore {
    label = "plugin-sdk-test-kvs"
    name = "formae-plugin-sdk-test-kvs-\(testRunID)"
    comment = "Plugin SDK test KVS"
  }
}
