amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/vpc.pkl"
import "@aws/ec2/subnet.pkl"
import "@aws/rds/dbsubnetgroup.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-rds-dbsubnetgroup-\(testRunID)"

// VPC dependency
local testVpc = new vpc.VPC {
  label = "test-vpc-for-dbsg"
  cidrBlock = "10.228.0.0/16"
  enableDnsSupport = true
}

// Two subnets in different AZs required for DB Subnet Group
local testSubnet1 = new subnet.Subnet {
  label = "test-subnet-1-for-dbsg"
  vpcId = testVpc.res.vpcId
  cidrBlock = "10.228.1.0/24"
  availabilityZone = "us-east-1a"
}

local testSubnet2 = new subnet.Subnet {
  label = "test-subnet-2-for-dbsg"
  vpcId = testVpc.res.vpcId
  cidrBlock = "10.228.2.0/24"
  availabilityZone = "us-east-1b"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for RDS DBSubnetGroup"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // VPC required for DB Subnet Group
  testVpc

  // Subnets required for DB Subnet Group (minimum 2 AZs)
  testSubnet1
  testSubnet2

  // DB Subnet Group under test - updated: change description
  new dbsubnetgroup.DBSubnetGroup {
    label = "plugin-sdk-test-dbsg"
    dbSubnetGroupName = "formae-sdk-test-dbsg-\(testRunID)"
    dbSubnetGroupDescription = "Test DB subnet group updated"
    subnetIds {
      testSubnet1.res.subnetId
      testSubnet2.res.subnetId
    }
  }
}
