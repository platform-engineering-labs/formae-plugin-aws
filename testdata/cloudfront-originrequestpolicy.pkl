amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/cloudfront/originrequestpolicy.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-cloudfront-originrequestpolicy-\(testRunID)"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for CloudFront OriginRequestPolicy"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  new originrequestpolicy.OriginRequestPolicy {
    label = "plugin-sdk-test-orp"
    originRequestPolicyConfig = new originrequestpolicy.OriginRequestPolicyConfig {
      name = "formae-plugin-sdk-test-orp-\(testRunID)"
      comment = "Plugin SDK test OriginRequestPolicy"
      headersConfig = new originrequestpolicy.OriginRequestPolicyHeadersConfig {
        headerBehavior = "none"
      }
      cookiesConfig = new originrequestpolicy.OriginRequestPolicyCookiesConfig {
        cookieBehavior = "none"
      }
      queryStringsConfig = new originrequestpolicy.OriginRequestPolicyQueryStringsConfig {
        queryStringBehavior = "none"
      }
    }
  }
}
