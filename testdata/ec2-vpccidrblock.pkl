amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/vpc.pkl"
import "@aws/ec2/vpccidrblock.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-vpccidrblock-\(testRunID)"

// VPC dependency - VPCCidrBlock associates a secondary CIDR to a VPC
local testVpc = new vpc.VPC {
  label = "test-vpc-for-vpccidrblock"
  cidrBlock = "10.0.0.0/16"
  enableDnsSupport = true
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 VPCCidrBlock"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // VPC required for VPCCidrBlock
  testVpc

  // VPCCidrBlock under test - secondary IPv4 CIDR (non-overlapping with the
  // VPC primary CIDR)
  new vpccidrblock.VPCCidrBlock {
    label = "plugin-sdk-test-vpccidrblock"
    vpcId = testVpc.res.vpcId
    cidrBlock = "10.1.0.0/16"
  }
}
