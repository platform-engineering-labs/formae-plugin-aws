amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/iam/user.pkl"
import "@aws/iam/accesskey.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-iam-accesskey-\(testRunID)"

local testUser = new user.User {
  label = "test-user"
  userName = "formae-sdk-test-accesskey-user-\(testRunID)"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for IAM AccessKey"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  testUser

  new accesskey.AccessKey {
    label = "plugin-sdk-test-accesskey"
    userName = testUser.res.userName
    status = "Active"
  }
}
