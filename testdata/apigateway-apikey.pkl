amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/apigateway/apikey.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-apigateway-apikey-\(testRunID)"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for ApiGateway ApiKey"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  new apikey.ApiKey {
    label = "plugin-sdk-test-apikey"
    name = "formae-sdk-test-apikey-\(testRunID)"
    enabled = true
    description = "Test API Key"
  }
}
