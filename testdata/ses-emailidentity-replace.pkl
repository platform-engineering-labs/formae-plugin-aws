amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ses/ses.pkl" as ses
import "@aws/ses/emailidentity.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ses-emailidentity-\(testRunID)"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for SES EmailIdentity"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // Replaced emailIdentity (createOnly field) — forces destroy/recreate
  new emailidentity.EmailIdentity {
    label = "plugin-sdk-test-emailidentity"
    emailIdentity = "formae-conformance-replaced-\(testRunID).example.com"
    mailFrom = new ses.MailFromAttributes {
      mailFromDomain = "mail.formae-conformance-replaced-\(testRunID).example.com"
      behaviorOnMxFailure = "USE_DEFAULT_VALUE"
    }
    dkimSigning = new ses.DkimSigningAttributes {
      nextSigningKeyLength = "RSA_2048_BIT"
    }
    feedback = new ses.FeedbackAttributes {
      emailForwardingEnabled = true
    }
    tags {
      new { key = "Environment"; value = "test" }
    }
  }
}
