amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/certificatemanager/certificate.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-certificatemanager-certificate-\(testRunID)"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for ACM Certificate"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  new certificate.Certificate {
    label = "plugin-sdk-test-cert"
    domainName = "formae-plugin-sdk-test-cert-\(testRunID).example"
    validationMethod = "DNS"
    keyAlgorithm = "RSA_2048"
    tags = new Listing<aws.Tag> {
      new { key = "Owner"; value = "plugin-sdk" }
    }
  }
}
