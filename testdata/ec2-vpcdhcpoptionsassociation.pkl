amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/vpc.pkl"
import "@aws/ec2/dhcpoptions.pkl"
import "@aws/ec2/vpcdhcpoptionsassociation.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-vpcdhcpoptionsassociation-\(testRunID)"

// VPC dependency
local testVpc = new vpc.VPC {
  label = "test-vpc-for-dhcpassoc"
  cidrBlock = "10.0.0.0/16"
  enableDnsSupport = true
}

// DHCPOptions dependency
local testDhcpOptions = new dhcpoptions.DHCPOptions {
  label = "test-dhcpoptions-for-assoc"
  domainName = "sdk-test.internal"
  domainNameServers {
    "AmazonProvidedDNS"
  }
  tags {
    new { key = "Name"; value = "formae-plugin-sdk-test-dhcp-for-assoc-\(testRunID)" }
  }
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 VPCDHCPOptionsAssociation"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // VPC required for the association
  testVpc

  // DHCPOptions required for the association
  testDhcpOptions

  // VPCDHCPOptionsAssociation under test
  new vpcdhcpoptionsassociation.VPCDHCPOptionsAssociation {
    label = "plugin-sdk-test-vpcdhcpoptionsassociation"
    vpcId = testVpc.res.vpcId
    dhcpOptionsId = testDhcpOptions.res.dhcpOptionsId
  }
}
