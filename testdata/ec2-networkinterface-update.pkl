amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/vpc.pkl"
import "@aws/ec2/subnet.pkl"
import "@aws/ec2/networkinterface.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-networkinterface-\(testRunID)"

// VPC dependency
local testVpc = new vpc.VPC {
  label = "test-vpc-for-eni"
  cidrBlock = "10.223.0.0/16"
  enableDnsSupport = true
}

// Subnet dependency
local testSubnet = new subnet.Subnet {
  label = "test-subnet-for-eni"
  vpcId = testVpc.res.vpcId
  cidrBlock = "10.223.1.0/24"
  availabilityZone = "us-east-1a"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 NetworkInterface"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // VPC required for NetworkInterface
  testVpc

  // Subnet required for NetworkInterface
  testSubnet

  // NetworkInterface under test - updated: change description
  new networkinterface.NetworkInterface {
    label = "plugin-sdk-test-eni"
    subnetId = testSubnet.res.subnetId
    description = "Test network interface updated"
  }
}
