amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/iam/role.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-iam-role-multi-inline-\(testRunID)"

// Update variant: the same role and the same set of inline policies in the same
// declaration order, but with one policy document edited — an extra action is
// added to "stream-read". This proves that editing a single inline policy on a
// multi-policy role round-trips: the Atomic whole-array replace re-sends every
// inline policy with the edited document applied, and a subsequent sync detects no
// residual drift.
forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for IAM Role with multiple inline policies"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  new role.Role {
    label = "plugin-sdk-test-role-multi-inline"
    roleName = "formae-plugin-sdk-test-role-multi-\(testRunID)"
    assumeRolePolicyDocument {
      ["Version"] = "2012-10-17"
      ["Statement"] {
        new {
          ["Effect"] = "Allow"
          ["Principal"] {
            ["Service"] = "lambda.amazonaws.com"
          }
          ["Action"] = "sts:AssumeRole"
        }
      }
    }
    policies {
      new {
        policyName = "state-table-rw"
        policyDocument {
          ["Version"] = "2012-10-17"
          ["Statement"] {
            new {
              ["Effect"] = "Allow"
              ["Action"] = new Listing {
                "dynamodb:GetItem"
                "dynamodb:PutItem"
                "dynamodb:UpdateItem"
              }
              ["Resource"] = "*"
            }
          }
        }
      }
      new {
        policyName = "stream-read"
        policyDocument {
          ["Version"] = "2012-10-17"
          ["Statement"] {
            new {
              ["Effect"] = "Allow"
              ["Action"] = new Listing {
                "dynamodb:GetRecords"
                "dynamodb:GetShardIterator"
                "dynamodb:DescribeStream"
                "dynamodb:ListStreams"
              }
              ["Resource"] = "*"
            }
          }
        }
      }
      new {
        policyName = "put-events"
        policyDocument {
          ["Version"] = "2012-10-17"
          ["Statement"] {
            new {
              ["Effect"] = "Allow"
              ["Action"] = "events:PutEvents"
              ["Resource"] = "*"
            }
          }
        }
      }
      new {
        policyName = "dlq-send"
        policyDocument {
          ["Version"] = "2012-10-17"
          ["Statement"] {
            new {
              ["Effect"] = "Allow"
              ["Action"] = "sqs:SendMessage"
              ["Resource"] = "*"
            }
          }
        }
      }
    }
  }
}
