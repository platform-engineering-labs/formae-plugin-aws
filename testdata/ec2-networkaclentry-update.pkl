amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/vpc.pkl"
import "@aws/ec2/networkacl.pkl"
import "@aws/ec2/networkaclentry.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-networkaclentry-\(testRunID)"

// VPC dependency
local testVpc = new vpc.VPC {
  label = "test-vpc-for-networkaclentry"
  cidrBlock = "10.0.0.0/16"
  enableDnsSupport = true
}

// NetworkAcl dependency
local testNetworkAcl = new networkacl.NetworkAcl {
  label = "test-networkacl-for-entry"
  vpcId = testVpc.res.vpcId
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 NetworkAclEntry"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // VPC required for NetworkAcl
  testVpc

  // NetworkAcl required for NetworkAclEntry
  testNetworkAcl

  // NetworkAclEntry under test - updated ruleAction to deny
  new networkaclentry.NetworkAclEntry {
    label = "plugin-sdk-test-networkaclentry"
    networkAclId = new formae.Resolvable {
      label = testNetworkAcl.label
      type = "AWS::EC2::NetworkAcl"
      property = "Id"
    }
    ruleNumber = 100
    protocol = 6
    ruleAction = "deny"
    cidrBlock = "10.0.0.0/8"
    egress = false
    portRange = new networkaclentry.PortRange {
      from = 80
      to = 80
    }
  }
}
