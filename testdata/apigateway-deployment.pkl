amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/apigateway/restapi.pkl"
import "@aws/apigateway/resource.pkl"
import "@aws/apigateway/method.pkl"
import "@aws/apigateway/deployment.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-apigateway-deployment-\(testRunID)"

// RestApi dependency
local testApi = new restapi.RestApi {
  label = "test-restapi-for-deployment"
  name = "formae-sdk-test-depl-api-\(testRunID)"
  description = "Test API for Deployment"
  endpointConfiguration = new restapi.EndpointConfiguration {
    types = new Listing { "REGIONAL" }
  }
}

// Resource dependency - Deployment requires at least one method on the API
local testResource = new resource.Resource {
  label = "test-resource-for-deployment"
  restApiId = testApi.res.restApiId
  parentId = testApi.res.rootResourceId
  pathPart = "test"
}

// Method dependency - API must have a method before deployment
local testMethod = new method.Method {
  label = "test-method-for-deployment"
  restApiId = testApi.res.restApiId
  resourceId = testResource.res.resourceId
  httpMethod = "GET"
  authorizationType = "NONE"
  integration = new method.Integration {
    type = "MOCK"
    requestTemplates {
      ["application/json"] = "{\"statusCode\": 200}"
    }
    integrationResponses {
      new {
        statusCode = "200"
        responseTemplates {
          ["application/json"] = "{}"
        }
      }
    }
  }
  methodResponses {
    new {
      statusCode = "200"
    }
  }
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for ApiGateway Deployment"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // Parent RestApi
  testApi

  // Resource (needed for method)
  testResource

  // Method (needed for deployment)
  testMethod

  // Deployment under test
  new deployment.Deployment {
    label = "plugin-sdk-test-deployment"
    restApiId = testApi.res.restApiId
    description = testMethod.res.resourceId
  }
}
