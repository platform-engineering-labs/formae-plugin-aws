amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/ipam.pkl"
import "@aws/ec2/ipamscope.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-ipamscope-\(testRunID)"

// IPAM dependency. The Name tag mirrors the formae label so CI cleanup
// catches orphans even when a test aborts before its teardown runs.
local testIpam = new ipam.IPAM {
  label = "test-ipam-for-scope"
  description = "IPAM for IPAMScope test"
  operatingRegions {
    new { regionName = "us-east-1" }
  }
  tags {
    new { key = "Name"; value = "formae-plugin-sdk-test-ipam-for-scope-\(testRunID)" }
  }
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 IPAMScope"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // IPAM required for the custom scope
  testIpam

  // IPAMScope under test
  new ipamscope.IPAMScope {
    label = "plugin-sdk-test-ipamscope"
    ipamId = testIpam.res.ipamId
    description = "Plugin SDK test IPAM scope"
    tags {
      new { key = "Name"; value = "formae-plugin-sdk-test-ipamscope-\(testRunID)" }
    }
  }
}
