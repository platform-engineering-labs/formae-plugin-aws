amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/vpc.pkl"
import "@aws/ec2/flowlog.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-flowlog-\(testRunID)"
local logGroupNameValue = "/formae/plugin-sdk-test/flowlog/\(testRunID)"

// VPC dependency (needed for required resourceId resolvable)
local testVpc = new vpc.VPC {
  label = "test-vpc-for-flowlog"
  cidrBlock = "10.210.0.0/16"
  enableDnsSupport = true
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 FlowLog"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // VPC (required for resourceId)
  testVpc

  // Updated: added tags (tags is the only updatable field on FlowLog)
  // Omit deliverLogsPermissionArn (createOnly resolvable to IAM role)
  // to avoid resolve cache timeouts during patch-mode update.
  new flowlog.FlowLog {
    label = "plugin-sdk-test-flowlog"
    resourceId = testVpc.res.vpcId
    resourceType = "VPC"
    trafficType = "ALL"
    logDestinationType = "cloud-watch-logs"
    logGroupName = logGroupNameValue
    tags {
      new { key = "Environment"; value = "updated" }
    }
  }
}
