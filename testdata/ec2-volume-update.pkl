amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/ec2/volume.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-ec2-volume-\(testRunID)"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for EC2 Volume"
  }

  new formae.Target {
    label = "aws-target"
    config = new aws.Config {
      region = "us-east-1"
    }
  }

  // EBS Volume under test - updated: change size to 2
  new volume.Volume {
    label = "plugin-sdk-test-volume"
    availabilityZone = "us-east-1a"
    size = 2
    volumeType = "gp3"
  }
}
