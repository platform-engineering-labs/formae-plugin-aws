import "@formae/formae.pkl"
import "@aws/aws.pkl"

projectName = "formae-bootstrap"
region = "us-east-2"
availabilityZone1 = "us-east-2a"
availabilityZone2 = "us-east-2b"
vpcCidr = "10.100.0.0/16"
subnetCidr1 = "10.100.1.0/24"
subnetCidr2 = "10.100.2.0/24"
dbName = "formae"
dbUser = "formae"
dbInstanceClass = "db.t4g.micro"
dbEngineVersion = "16.14"
formaeImage = "ghcr.io/platform-engineering-labs/formae:0.86.0"
formaePort = 49684

stack: formae.Stack = new {
    label = "formae-bootstrap"
    description = "Formae production infrastructure on AWS"
}

target: formae.Target = new formae.Target {
    label = "bootstrap-target"
    config = new aws.Config {
        region = module.region
    }
}

regionProp: formae.Prop = new {
    flag = "region"
    default = module.region
}
