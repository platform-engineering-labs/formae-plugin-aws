import "@formae/formae.pkl"
import "@aws/ec2/vpc.pkl"
import "@aws/ec2/subnet.pkl"
import "@aws/ec2/securitygroup.pkl"
import "@aws/ec2/securitygroupingress.pkl"
import "@aws/ec2/securitygroupegress.pkl"
import "@aws/ecs/ecscluster.pkl"
import "@aws/ecs/taskdefinition.pkl"
import "@aws/ecs/service.pkl"
import "@aws/iam/role.pkl"
import "@aws/logs/loggroup.pkl"
import "@aws/elasticloadbalancingv2/loadbalancer.pkl"
import "@aws/elasticloadbalancingv2/targetgroup.pkl"
import "@aws/elasticloadbalancingv2/listener.pkl"
import "@aws/rds/dbcluster.pkl"

class EcsResources {
    projectName: String
    region: String
    formaeImage: String
    formaePort: Int
    dbName: String
    stackLabel: String
    vpc: vpc.VPC
    subnet1: subnet.Subnet
    subnet2: subnet.Subnet
    auroraCluster: dbcluster.DBCluster

    // --- IAM ---

    hidden taskExecRole: role.Role = new {
        label = "\(projectName)-task-exec-role"
        roleName = "\(projectName)-task-exec-role"
        assumeRolePolicyDocument {
            ["Version"] = "2012-10-17"
            ["Statement"] {
                ["Effect"] = "Allow"
                ["Principal"] {
                    ["Service"] = "ecs-tasks.amazonaws.com"
                }
                ["Action"] = "sts:AssumeRole"
            }
        }
        managedPolicyArns {
            "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy"
        }
        tags { new { key = "Name"; value = "\(projectName)-task-exec-role" } }
    }

    hidden taskRole: role.Role = new {
        label = "\(projectName)-task-role"
        roleName = "\(projectName)-task-role"
        assumeRolePolicyDocument {
            ["Version"] = "2012-10-17"
            ["Statement"] {
                ["Effect"] = "Allow"
                ["Principal"] {
                    ["Service"] = "ecs-tasks.amazonaws.com"
                }
                ["Action"] = "sts:AssumeRole"
            }
        }
        policies {
            new role.RolePolicy {
                policyName = "\(projectName)-aurora-data-api"
                policyDocument {
                    ["Version"] = "2012-10-17"
                    ["Statement"] = new Listing {
                        new Dynamic {
                            ["Effect"] = "Allow"
                            ["Action"] = new Listing {
                                "rds-data:ExecuteStatement"
                                "rds-data:BatchExecuteStatement"
                                "rds-data:BeginTransaction"
                                "rds-data:CommitTransaction"
                                "rds-data:RollbackTransaction"
                            }
                            ["Resource"] = "*"
                        }
                        new Dynamic {
                            ["Effect"] = "Allow"
                            ["Action"] = new Listing {
                                "secretsmanager:GetSecretValue"
                            }
                            ["Resource"] = "*"
                        }
                    }
                }
            }
        }
        tags { new { key = "Name"; value = "\(projectName)-task-role" } }
    }

    // --- Logging ---

    hidden logGroup: loggroup.LogGroup = new {
        label = "\(projectName)-log-group"
        logGroupName = "/ecs/\(projectName)"
        retentionInDays = 14
        tags { new { key = "Name"; value = "\(projectName)-log-group" } }
    }

    // --- Security Groups ---

    hidden albSg: securitygroup.SecurityGroup = new {
        label = "\(projectName)-alb-sg"
        groupDescription = "Allow traffic to formae ALB"
        vpcId = vpc.res.id
        tags { new { key = "Name"; value = "\(projectName)-alb-sg" } }
    }

    hidden albIngress: securitygroupingress.SecurityGroupIngress = new {
        label = "\(projectName)-alb-sg-ingress"
        ipProtocol = "tcp"
        fromPort = formaePort
        toPort = formaePort
        cidrIp = "0.0.0.0/0"
        groupId = albSg.res.groupId
    }

    hidden taskSg: securitygroup.SecurityGroup = new {
        label = "\(projectName)-task-sg"
        groupDescription = "Allow traffic from ALB to formae tasks"
        vpcId = vpc.res.id
        tags { new { key = "Name"; value = "\(projectName)-task-sg" } }
    }

    hidden taskIngress: securitygroupingress.SecurityGroupIngress = new {
        label = "\(projectName)-task-sg-ingress"
        ipProtocol = "tcp"
        fromPort = formaePort
        toPort = formaePort
        sourceSecurityGroupId = albSg.res.groupId
        groupId = taskSg.res.groupId
    }

    // --- ECS ---

    hidden ecsCluster: ecscluster.Cluster = new {
        label = "\(projectName)-cluster"
        clusterName = "\(projectName)-cluster"
        tags { new { key = "Name"; value = "\(projectName)-cluster" } }
    }

    local configScript = new Listing {
        "cat > /home/pel/.config/formae/formae.conf.pkl << 'PKLEOF'"
        "amends \"formae:/Config.pkl\""
        ""
        "agent {"
        "  server {"
        "    port = \(formaePort)"
        "  }"
        "  datastore {"
        "    datastoreType = \"auroradataapi\""
        "    auroraDataAPI {"
        "      clusterArn = \"${FORMAE_CLUSTER_ARN}\""
        "      secretArn = \"${FORMAE_SECRET_ARN}\""
        "      database = \"\(dbName)\""
        "      region = \"\(region)\""
        "    }"
        "  }"
        "  synchronization {"
        "    enabled = true"
        "    interval = 300.s"
        "  }"
        "  discovery {"
        "    enabled = true"
        "    interval = 600.s"
        "  }"
        "}"
        "PKLEOF"
        "exec formae agent start"
    }.join("\n")

    hidden taskDef: taskdefinition.TaskDefinition = new {
        label = "\(projectName)-task-def"
        family = "\(projectName)-task"
        requiresCompatibilities { "FARGATE" }
        networkMode = "awsvpc"
        cpu = "512"
        memory = "1024"
        executionRoleArn = taskExecRole.res.arn
        taskRoleArn = taskRole.res.arn

        containerDefinitions {
            new taskdefinition.ContainerDefinition {
                name = "formae"
                image = formaeImage
                essential = true
                entryPoint { "sh"; "-c" }
                command { configScript }
                portMappings {
                    new taskdefinition.PortMapping {
                        containerPort = formaePort
                        protocol = "tcp"
                    }
                }
                environment {
                    new taskdefinition.KeyValuePair {
                        name = "FORMAE_CLUSTER_ARN"
                        value = auroraCluster.res.dbClusterArn
                    }
                    new taskdefinition.KeyValuePair {
                        name = "FORMAE_SECRET_ARN"
                        value = auroraCluster.res.masterUserSecretSecretArn
                    }
                }
                logConfiguration = new taskdefinition.LogConfiguration {
                    logDriver = "awslogs"
                    options {
                        ["awslogs-group"] = "/ecs/\(projectName)"
                        ["awslogs-region"] = region
                        ["awslogs-stream-prefix"] = "formae"
                    }
                }
            }
        }
        tags { new { key = "Name"; value = "\(projectName)-task-def" } }
    }

    // --- Load Balancer ---

    hidden alb: loadbalancer.LoadBalancer = new {
        label = "\(projectName)-alb"
        name = "\(projectName)-alb"
        subnets { subnet1.res.subnetId; subnet2.res.subnetId }
        securityGroups { albSg.res.groupId }
        scheme = "internet-facing"
        type = "application"
        tags { new { key = "Name"; value = "\(projectName)-alb" } }
    }

    hidden tg: targetgroup.TargetGroup = new {
        label = "\(projectName)-tg"
        name = "\(projectName)-tg"
        vpcId = vpc.res.id
        port = formaePort
        protocol = "HTTP"
        targetType = "ip"
        healthCheckEnabled = true
        healthCheckPath = "/api/v1/health"
        healthCheckProtocol = "HTTP"
        healthCheckPort = String(formaePort)
        matcher = new targetgroup.Matcher { httpCode = "200" }
        healthCheckIntervalSeconds = 30
        tags { new { key = "Name"; value = "\(projectName)-tg" } }
    }

    hidden albListener: listener.Listener = new {
        label = "\(projectName)-listener"
        loadBalancerArn = alb.res.loadBalancerArn
        port = formaePort
        protocol = "HTTP"
        defaultActions {
            new listener.Action {
                type = "forward"
                targetGroupArn = tg.res.targetGroupArn
            }
        }
    }

    // --- ECS Service ---

    hidden ecsService: service.Service = new {
        label = "\(projectName)-service"
        serviceName = "\(projectName)-service"
        cluster = ecsCluster.res.arn
        taskDefinition = new taskdefinition.TaskDefinitionResolvable {
            label = taskDef.label
            stack = stackLabel
        }.taskDefinitionArn
        desiredCount = 1
        launchType = "FARGATE"
        networkConfiguration = new service.NetworkConfiguration {
            awsvpcConfiguration = new service.AwsVpcConfiguration {
                assignPublicIp = "ENABLED"
                subnets { subnet1.res.subnetId; subnet2.res.subnetId }
                securityGroups { taskSg.res.groupId }
            }
        }
        loadBalancers {
            new service.LoadBalancer {
                targetGroupArn = tg.res.targetGroupArn
                containerName = "formae"
                containerPort = formaePort
            }
        }
        tags { new { key = "Name"; value = "\(projectName)-service" } }
    }

    hidden resources: Listing<formae.Resource> = new {
        taskExecRole
        taskRole
        logGroup
        albSg
        albIngress
        taskSg
        taskIngress
        ecsCluster
        taskDef
        alb
        tg
        albListener
        ecsService
    }
}
