amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/ec2/vpc.pkl"
import "@aws/ec2/internetgateway.pkl"
import "@aws/ec2/vpcgatewayattachment.pkl"
import "@aws/ec2/subnet.pkl"
import "@aws/ec2/routetable.pkl"
import "@aws/ec2/route.pkl"
import "@aws/ec2/subnetroutetableassociation.pkl"
import "@aws/ec2/securitygroup.pkl"
import "@aws/ec2/securitygroupingress.pkl"

import "@aws/rds/dbinstance.pkl"
import "@aws/rds/dbsubnetgroup.pkl"
import "@aws/secretsmanager/secret.pkl"
import "@formae/ext/random.pkl"

import "@aws/ecs/ecscluster.pkl"
import "@aws/ecs/taskdefinition.pkl"
import "@aws/ecs/service.pkl"

import "@aws/iam/role.pkl"

import "@aws/logs/loggroup.pkl"

import "@aws/elasticloadbalancingv2/loadbalancer.pkl"
import "@aws/elasticloadbalancingv2/targetgroup.pkl"
import "@aws/elasticloadbalancingv2/listener.pkl"

import "./vars.pkl"

description {
    text = """
    Formae Bootstrap on AWS

    Provisions:
    - VPC with two public subnets across availability zones
    - RDS PostgreSQL (db.t4g.micro) with a generated master password in Secrets Manager
    - ECS Fargate cluster running the formae agent (connects to Postgres over TCP)
    - Application Load Balancer for API access
    - IAM roles for ECS task execution + Secrets Manager access
    """
    confirm = true
}

properties {
    name = new formae.Prop {
        flag = "name"
        default = vars.projectName
    }
    region = vars.regionProp
}

local n = properties.name.value

forma {
    vars.stack
    vars.target

    local vpcRes = new vpc.VPC {
        label = "\(n)-vpc"
        cidrBlock = vars.vpcCidr
        enableDnsHostnames = true
        enableDnsSupport = true
        tags { new { key = "Name"; value = "\(n)-vpc" } }
    }
    vpcRes

    local igw = new internetgateway.InternetGateway {
        label = "\(n)-igw"
        tags { new { key = "Name"; value = "\(n)-igw" } }
    }
    igw

    new vpcgatewayattachment.VPCGatewayAttachment {
        label = "\(n)-igw-attach"
        vpcId = vpcRes.res.id
        internetGatewayId = igw.res.id
    }

    local subnet1 = new subnet.Subnet {
        label = "\(n)-subnet-1"
        vpcId = vpcRes.res.id
        cidrBlock = vars.subnetCidr1
        availabilityZone = vars.availabilityZone1
        mapPublicIpOnLaunch = true
        tags { new { key = "Name"; value = "\(n)-subnet-1" } }
    }
    subnet1

    local subnet2 = new subnet.Subnet {
        label = "\(n)-subnet-2"
        vpcId = vpcRes.res.id
        cidrBlock = vars.subnetCidr2
        availabilityZone = vars.availabilityZone2
        mapPublicIpOnLaunch = true
        tags { new { key = "Name"; value = "\(n)-subnet-2" } }
    }
    subnet2

    local rt = new routetable.RouteTable {
        label = "\(n)-rt"
        vpcId = vpcRes.res.id
        tags { new { key = "Name"; value = "\(n)-rt" } }
    }
    rt

    new route.Route {
        label = "\(n)-route"
        routeTableId = rt.res.id
        destinationCidrBlock = "0.0.0.0/0"
        gatewayId = igw.res.id
    }

    new subnetroutetableassociation.SubnetRouteTableAssociation {
        label = "\(n)-rt-assoc-1"
        subnetId = subnet1.res.id
        routeTableId = rt.res.id
    }

    new subnetroutetableassociation.SubnetRouteTableAssociation {
        label = "\(n)-rt-assoc-2"
        subnetId = subnet2.res.id
        routeTableId = rt.res.id
    }

    local dbSg = new securitygroup.SecurityGroup {
        label = "\(n)-db-sg"
        groupDescription = "Allow PostgreSQL from within the VPC (the ECS task)"
        vpcId = vpcRes.res.id
        tags { new { key = "Name"; value = "\(n)-db-sg" } }
    }
    dbSg

    new securitygroupingress.SecurityGroupIngress {
        label = "\(n)-db-sg-ingress"
        ipProtocol = "tcp"
        fromPort = 5432
        toPort = 5432
        cidrIp = vars.vpcCidr
        groupId = dbSg.res.groupId
    }

    local dbSubnetGroup = new dbsubnetgroup.DBSubnetGroup {
        label = "\(n)-db-subnet-group"
        dbSubnetGroupDescription = "Subnet group for the formae database"
        subnetIds { subnet1.res.subnetId; subnet2.res.subnetId }
        tags { new { key = "Name"; value = "\(n)-db-subnet-group" } }
    }
    dbSubnetGroup

    local dbSecret = new secret.Secret {
        label = "\(n)-db-secret"
        name = "\(n)-db-password"
        description = "formae database master password (generated)"
        secretString = formae.value(random.password(24, false)).opaque.setOnce
    }
    dbSecret

    // The agent reaches this DB over TCP (5432) with the password from the secret
    // above; the writer endpoint feeds its config at startup.
    local db = new dbinstance.DBInstance {
        label = "\(n)-db"
        dbInstanceIdentifier = "\(n)-db"
        engine = "postgres"
        engineVersion = vars.dbEngineVersion
        dbInstanceClass = vars.dbInstanceClass
        allocatedStorage = "20"
        dbName = vars.dbName
        masterUsername = vars.dbUser
        masterUserPassword = dbSecret.res.secretString
        dbSubnetGroupName = dbSubnetGroup.res.dbSubnetGroupName
        vpcSecurityGroups { dbSg.res.groupId }
        storageEncrypted = true
        publiclyAccessible = false
        multiAZ = false
        tags { new { key = "Name"; value = "\(n)-db" } }
    }
    db

    local ecsAssumeRole = new Dynamic {
        ["Version"] = "2012-10-17"
        ["Statement"] = new Listing {
            new Dynamic {
                ["Effect"] = "Allow"
                ["Principal"] = new Dynamic { ["Service"] = "ecs-tasks.amazonaws.com" }
                ["Action"] = "sts:AssumeRole"
            }
        }
    }

    local taskExecRole = new role.Role {
        label = "\(n)-exec-role"
        roleName = "\(n)-exec-role"
        assumeRolePolicyDocument = ecsAssumeRole
        managedPolicyArns {
            "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy"
        }
        policies {
            new role.RolePolicy {
                policyName = "\(n)-secrets-access"
                policyDocument {
                    ["Version"] = "2012-10-17"
                    ["Statement"] = new Listing {
                        new Dynamic {
                            ["Effect"] = "Allow"
                            ["Action"] = "secretsmanager:GetSecretValue"
                            ["Resource"] = "*"
                        }
                    }
                }
            }
        }
        tags { new { key = "Name"; value = "\(n)-exec-role" } }
    }
    taskExecRole

    // SSM channel perms so `aws ecs execute-command` can shell into the running agent.
    local taskRole = new role.Role {
        label = "\(n)-task-role"
        roleName = "\(n)-task-role"
        assumeRolePolicyDocument = ecsAssumeRole
        policies {
            new role.RolePolicy {
                policyName = "\(n)-ecs-exec"
                policyDocument {
                    ["Version"] = "2012-10-17"
                    ["Statement"] = new Listing {
                        new Dynamic {
                            ["Effect"] = "Allow"
                            ["Action"] = new Listing {
                                "ssmmessages:CreateControlChannel"
                                "ssmmessages:CreateDataChannel"
                                "ssmmessages:OpenControlChannel"
                                "ssmmessages:OpenDataChannel"
                            }
                            ["Resource"] = "*"
                        }
                    }
                }
            }
        }
        tags { new { key = "Name"; value = "\(n)-task-role" } }
    }
    taskRole

    local logGrp = new loggroup.LogGroup {
        label = "\(n)-logs"
        logGroupName = "/ecs/\(n)"
        retentionInDays = 14
    }
    logGrp

    local ecsCluster = new ecscluster.Cluster {
        label = "\(n)-ecs-cluster"
        clusterName = "\(n)-cluster"
        tags { new { key = "Name"; value = "\(n)-cluster" } }
    }
    ecsCluster

    local configScript = new Listing {
        "mkdir -p /home/pel/.config/formae &&"
        "cat > /home/pel/.config/formae/formae.conf.pkl << PKLEOF"
        "amends \"formae:/Config.pkl\""
        "agent {"
        "  server {"
        "    port = \(vars.formaePort)"
        "  }"
        "  datastore {"
        "    datastoreType = \"postgres\""
        "    postgres {"
        "      host = \"$FORMAE_DB_HOST\""
        "      port = 5432"
        "      user = \"\(vars.dbUser)\""
        "      password = \"$FORMAE_DB_PASSWORD\""
        "      database = \"\(vars.dbName)\""
        "      connectionParams = \"sslmode=require\""
        "    }"
        "  }"
        "  synchronization {"
        "    enabled = true"
        "    interval = 300.s"
        "  }"
        "  discovery {"
        "    enabled = true"
        "    interval = 600.s"
        "  }"
        "}"
        "PKLEOF"
        "exec formae agent start"
    }.join("\n")

    local taskDef = new taskdefinition.TaskDefinition {
        label = "\(n)-task-def"
        family = "\(n)-task"
        requiresCompatibilities { "FARGATE" }
        networkMode = "awsvpc"
        cpu = "512"
        memory = "1024"
        executionRoleArn = taskExecRole.res.arn
        taskRoleArn = taskRole.res.arn
        containerDefinitions {
            new taskdefinition.ContainerDefinition {
                name = "formae-agent"
                image = vars.formaeImage
                essential = true
                entryPoint { "sh"; "-c" }
                command { configScript }
                portMappings {
                    new taskdefinition.PortMapping {
                        containerPort = vars.formaePort
                        protocol = "tcp"
                    }
                }
                environment {
                    new taskdefinition.KeyValuePair {
                        name = "FORMAE_DB_HOST"
                        value = db.res.endpointAddress
                    }
                    // Plain env var, not ECS `secrets`: this plugin version can't resolve the
                    // in-stack Secret's ARN (NativeId is null), only its `secretString`. Trade-off:
                    // the password shows in the task def. For the ARN-based path, see existing-db.pkl.
                    new taskdefinition.KeyValuePair {
                        name = "FORMAE_DB_PASSWORD"
                        value = dbSecret.res.secretString
                    }
                }
                logConfiguration = new taskdefinition.LogConfiguration {
                    logDriver = "awslogs"
                    options {
                        ["awslogs-group"] = "/ecs/\(n)"
                        ["awslogs-region"] = vars.region
                        ["awslogs-stream-prefix"] = "formae"
                    }
                }
            }
        }
        tags { new { key = "Name"; value = "\(n)-task-def" } }
    }
    taskDef

    local albSg = new securitygroup.SecurityGroup {
        label = "\(n)-alb-sg"
        groupDescription = "Allow formae API traffic"
        vpcId = vpcRes.res.id
        tags { new { key = "Name"; value = "\(n)-alb-sg" } }
    }
    albSg

    new securitygroupingress.SecurityGroupIngress {
        label = "\(n)-alb-sg-ingress"
        ipProtocol = "tcp"
        fromPort = vars.formaePort
        toPort = vars.formaePort
        cidrIp = "0.0.0.0/0"
        groupId = albSg.res.groupId
    }

    local taskSg = new securitygroup.SecurityGroup {
        label = "\(n)-task-sg"
        groupDescription = "Allow traffic from ALB to formae tasks"
        vpcId = vpcRes.res.id
        tags { new { key = "Name"; value = "\(n)-task-sg" } }
    }
    taskSg

    new securitygroupingress.SecurityGroupIngress {
        label = "\(n)-task-sg-ingress"
        ipProtocol = "tcp"
        fromPort = vars.formaePort
        toPort = vars.formaePort
        sourceSecurityGroupId = albSg.res.groupId
        groupId = taskSg.res.groupId
    }

    local alb = new loadbalancer.LoadBalancer {
        label = "\(n)-alb"
        name = "\(n)-alb"
        subnets { subnet1.res.subnetId; subnet2.res.subnetId }
        securityGroups { albSg.res.groupId }
        scheme = "internet-facing"
        type = "application"
        tags { new { key = "Name"; value = "\(n)-alb" } }
    }
    alb

    local tg = new targetgroup.TargetGroup {
        label = "\(n)-tg"
        name = "\(n)-tg"
        vpcId = vpcRes.res.id
        port = vars.formaePort
        protocol = "HTTP"
        targetType = "ip"
        healthCheckEnabled = true
        healthCheckPath = "/api/v1/health"
        healthCheckProtocol = "HTTP"
        healthCheckPort = "\(vars.formaePort)"
        matcher = new targetgroup.Matcher { httpCode = "200" }
        healthCheckIntervalSeconds = 30
        tags { new { key = "Name"; value = "\(n)-tg" } }
    }
    tg

    new listener.Listener {
        label = "\(n)-listener"
        loadBalancerArn = alb.res.loadBalancerArn
        port = vars.formaePort
        protocol = "HTTP"
        defaultActions {
            new listener.Action {
                type = "forward"
                targetGroupArn = tg.res.targetGroupArn
            }
        }
    }

    new service.Service {
        label = "\(n)-ecs-service"
        serviceName = "\(n)-service"
        cluster = ecsCluster.res.arn
        taskDefinition = new taskdefinition.TaskDefinitionResolvable {
            label = taskDef.label
            stack = vars.stack.label
        }.taskDefinitionArn
        desiredCount = 1
        launchType = "FARGATE"
        enableExecuteCommand = true
        networkConfiguration = new service.NetworkConfiguration {
            awsvpcConfiguration = new service.AwsVpcConfiguration {
                assignPublicIp = "ENABLED"
                subnets { subnet1.res.subnetId; subnet2.res.subnetId }
                securityGroups { taskSg.res.groupId }
            }
        }
        loadBalancers {
            new service.LoadBalancer {
                targetGroupArn = tg.res.targetGroupArn
                containerName = "formae-agent"
                containerPort = vars.formaePort
            }
        }
        tags { new { key = "Name"; value = "\(n)-service" } }
    }
}
