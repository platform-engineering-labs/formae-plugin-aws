amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@aws/ec2/vpc.pkl"
import "@aws/ec2/subnet.pkl"
import "@aws/rds/dbcluster.pkl"

import "./infrastructure/ecs_resources.pkl"

import "./vars.pkl"

description {
    text = """
    Stage 2: Formae Bootstrap — Agent on ECS

    Provisions:
    - ECS Fargate cluster and service
    - IAM roles (task execution + Aurora Data API access)
    - Application Load Balancer for API access
    - CloudWatch log group

    The formae container generates its config at startup from environment
    variables, connecting to the Aurora cluster provisioned in Stage 1.
    """
    confirm = true
}

properties {
    name = new formae.Prop {
        flag = "name"
        default = vars.projectName
    }
    region = vars.regionProp
}

// Resolvables referencing Stage 1 resources (same stack)
local vpcRef = new vpc.VpcResolvable {
    label = "\(properties.name.value)-vpc"
    stack = vars.stack.label
}

local subnet1Ref = new subnet.SubnetResolvable {
    label = "\(properties.name.value)-public-subnet-1"
    stack = vars.stack.label
}

local subnet2Ref = new subnet.SubnetResolvable {
    label = "\(properties.name.value)-public-subnet-2"
    stack = vars.stack.label
}

local clusterRef = new dbcluster.DBClusterResolvable {
    label = "\(properties.name.value)-cluster"
    stack = vars.stack.label
}

local _ecs = new ecs_resources.EcsResources {
    projectName = properties.name.value
    region = properties.region.value
    stackLabel = vars.stack.label
    formaeImage = vars.formaeImage
    formaePort = vars.formaePort
    dbName = vars.dbName
    vpc = new vpc.VPC {
        label = "\(properties.name.value)-vpc"
        // VPC already exists — resolvable reference
        cidrBlock = vars.vpcCidr
    }
    subnet1 = new subnet.Subnet {
        label = "\(properties.name.value)-public-subnet-1"
        vpcId = vpcRef.id
        cidrBlock = vars.subnetCidr1
        availabilityZone = vars.availabilityZone1
    }
    subnet2 = new subnet.Subnet {
        label = "\(properties.name.value)-public-subnet-2"
        vpcId = vpcRef.id
        cidrBlock = vars.subnetCidr2
        availabilityZone = vars.availabilityZone2
    }
    auroraCluster = new dbcluster.DBCluster {
        label = "\(properties.name.value)-cluster"
        dbClusterIdentifier = "\(properties.name.value)-cluster"
        engine = "aurora-postgresql"
    }
}

forma {
    vars.stack
    vars.target

    ..._ecs.resources
}
