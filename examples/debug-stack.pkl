amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@aws/aws.pkl"
import "@aws/ec2/vpc.pkl"

description {
    text = "Debug stack test"
    confirm = false
}

forma {
    new formae.Stack {
        label = "my-debug-stack"
        description = "Debug stack description"
    }
    
    new formae.Target {
        label = "aws-target"
        config = new aws.Config {
            region = "us-east-1"
        }
    }
    
    // Add a resource to trigger defaultStack evaluation
    new vpc.VPC {
        label = "test-vpc"
        cidrBlock = "10.0.0.0/16"
    }
}
