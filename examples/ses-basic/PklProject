amends "pkl:Project"

// SES schemas are not yet in the published `aws` hub package; reference
// the local schema/pkl tree directly so this example evaluates against
// the same schema the plugin builds against. Once SES ships in a public
// `aws` release, this file can be removed and the example will pick up
// the top-level examples/PklProject.
dependencies {
  ["formae"] {
    uri = "package://hub.platform.engineering/plugins/pkl/schema/pkl/formae/formae@0.84.0"
  }
  ["aws"] = import("../../schema/pkl/PklProject")
}
