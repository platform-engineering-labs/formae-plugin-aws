extends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@aws/aws.pkl"

import "./types.pkl"
import "./vpc_resources.pkl"
import "./database_resources.pkl"

description {
    text = """
        This example shows how to abstract a whole database behind just a few high-level properties.

        Platform team is maintaining the detail, developers only use prescribed properties to spin up a database.
        """
    confirm = true
}

properties: Props

class Props {
    /// Team that owns the database
    team: types.Team = "team-a"

    /// Database size class
    size: String = "xs"
}

local _vpc = new vpc_resources.VpcResources {
    team = properties.team
}

local _database = new database_resources.DatabaseResources {
    team = properties.team
    size = properties.size
    vpc = _vpc.vpc
    subnet1 = _vpc.subnet1
    subnet2 = _vpc.subnet2
}

forma {
    new formae.Stack {
        label = "\(properties.team)-stack"
        description = "Stack for \(properties.team) infrastructure"
    }

    new formae.Target {
        label = "\(properties.team)-target"
        config = new aws.Config {
            region = types.regionFromTeam(properties.team)
        }
    }

    ..._vpc.resources
    ..._database.resources
}
